import { planner } from "../lib/plan.js"

// fields that get filled out over time
type Plan = {
  overallGoal: string;
  desiredActions: string[] # array of descriptions of each action
}

def newPlan(): Plan {
  """
  Create a new plan with empty goal and actions, set it as the current plan, and return it.
  """
  return planner.newPlan()
}

def getCurrentPlan(): Plan | null {
  """
  Return the current plan, or null if there is no current plan.
  """
  return planner.getCurrentPlan()
}

def listPlans(): Plan[] {
  """
  Return all plans stored in the planner.
  """
  return planner.listPlans()
}

def updateCurrentPlan(overallGoal: string, desiredActions: string[]): Plan | null {
  """
  Update the current plan with a new goal and actions, return the updated plan or null if no current plan.
  """
  return planner.updateCurrentPlan(overallGoal, desiredActions)
}

def updateGoal(overallGoal: string): Plan | null {
  """
  Update the overall goal of the current plan, return the updated plan or null if no current plan.
  """
  return planner.updateGoal(overallGoal)
}

def updateActions(desiredActions: string[]): Plan | null {
  """
  Update the actions of the current plan, return the updated plan or null if no current plan.
  """
  return planner.updateActions(desiredActions)
}