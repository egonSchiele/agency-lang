import { skillsDir } from "std::skills"

def stdDesc(): string {
  const tool = skillsDir(__dirname + "/skills-dir-fixture/std", "standard") with approve
  return tool.description
}

def flatDesc(): string {
  const tool = skillsDir(__dirname + "/skills-dir-fixture/flat", "flat") with approve
  return tool.description
}

def emptyDesc(): string {
  const tool = skillsDir(__dirname + "/skills-dir-fixture/empty", "flat") with approve
  return tool.description
}

node standardHasNamedSkill(): boolean {
  const d = stdDesc()
  return d.includes("<name>hello-world</name>")
      && d.includes("<description>Greet the world.</description>")
      && d.includes("<location>hello-world/SKILL.md</location>")
}

node standardFallsBackToDirNameWhenNoFrontmatter(): boolean {
  const d = stdDesc()
  return d.includes("<name>bare-skill</name>")
      && d.includes("<location>bare-skill/SKILL.md</location>")
}

node standardFallsBackToDirNameWhenNameAbsent(): boolean {
  const d = stdDesc()
  return d.includes("<name>no-name</name>")
      && d.includes("<description>This one is missing its name.</description>")
}

node flatHasNamedSkill(): boolean {
  const d = flatDesc()
  return d.includes("<name>greet</name>")
      && d.includes("<location>greet.md</location>")
}

node flatFallsBackToTitle(): boolean {
  const d = flatDesc()
  return d.includes("<name>vitepress-style</name>")
      && d.includes("<location>title-only.md</location>")
}

node flatFallsBackToFilenameWhenNoFrontmatter(): boolean {
  const d = flatDesc()
  return d.includes("<name>no-frontmatter.md</name>")
      && d.includes("<description></description>")
      && d.includes("<location>no-frontmatter.md</location>")
}

node flatXmlEscapesDescription(): boolean {
  const d = flatDesc()
  return d.includes("Has &lt;angle&gt; brackets &amp; ampersand.")
      && !d.includes("Has <angle>")
}

node emptyDirectoryProducesEmptySkillList(): boolean {
  const d = emptyDesc()
  return d.includes("<available_skills>\n\n</available_skills>")
}

// ---- Tool-name derivation: providers cap tool names (OpenAI 64), so a deep
// directory path must not overflow. A nonexistent dir is fine here — the tool
// name is derived from the path; the skill list is just empty.

const DEEP_BASE = "a/very/deeply/nested/path/that/keeps/going/and/going/until/it/overflows/the/limit/stdlib/docs"

def deepToolName(leaf: string): string {
  const tool = skillsDir("${DEEP_BASE}/${leaf}", "flat") with approve
  return tool.name
}

// A path long enough to overflow is capped to <= 64 chars.
node derivedNameCappedTo64(): boolean {
  return deepToolName("guide").length <= 64
}

// The cap keeps the distinctive TAIL (the leaf skill dir), not the shared
// leading path — so the name stays readable and meaningful.
node derivedNameKeepsTail(): boolean {
  return deepToolName("guide").endsWith("docs_guide")
}

// Two sibling deep paths still get DISTINCT capped names (uniqueness is what
// the derivation exists for; keeping the tail preserves it under the cap).
node siblingDeepPathsStayDistinct(): boolean {
  const guide = deepToolName("guide")
  const cli = deepToolName("cli")
  return guide != cli && guide.length <= 64 && cli.length <= 64
}

// An explicit name overrides the derived one.
node explicitNameOverrides(): boolean {
  const tool = skillsDir(__dirname + "/skills-dir-fixture/flat", "flat", "my_docs") with approve
  return tool.name == "my_docs"
}

// An explicit name is still sanitized (spaces/punctuation rejected by
// providers) and capped.
node explicitNameSanitized(): boolean {
  const tool = skillsDir(__dirname + "/skills-dir-fixture/flat", "flat", "My Cool Skill!") with approve
  return tool.name == "My_Cool_Skill"
}
