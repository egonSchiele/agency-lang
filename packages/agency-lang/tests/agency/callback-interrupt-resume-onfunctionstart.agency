
let calls: number = 0

// A top-level callback registered on onFunctionStart that raises an
// interrupt the first time it fires. Runner.hook halts the surrounding
// function's runner so the interrupt surfaces up the stack to the user.
//
// On resume the callback's own checkpoint (stamped inside its interrupt
// step before its frame was popped) restores the full stack with the
// callback frame's substep counters intact. The hook re-fires on doWork,
// the callback's setupFunction reuses the saved callback frame from the
// deserialize queue, the body's `calls = calls + 1` step is skipped
// (already past), only the interrupt step re-runs — and it finds the
// user's response via the saved __interruptId_N. Callback completes
// without re-throwing. doWork runs, main returns.
//
// Expected post-resume value: calls == 1 (the callback's increment
// substep was already past at checkpoint time, so it does NOT re-run
// on resume).
callback("onFunctionStart") as data {
  if (data.functionName == "doWork") {
    calls = calls + 1
    if (calls == 1) {
      interrupt("pause")
    }
  }
}

def doWork(): string {
  return "ok"
}

node main() {
  let r: string = doWork()
  return [calls, r]
}
