import { getMutable, setMutable } from "../../helpers/mutableVar.js"

node main() {
  const cp = checkpoint()
  setMutable("log", getMutable("log", "") + "start,")
  let x = 0
  while (x < 3) {
    setMutable("log", getMutable("log", "") + x)
    x = x + 1
  }
  if (getMutable("log", "") == "start,012") {
    restore(cp, {})
  }
  return getMutable("log", "")
}
