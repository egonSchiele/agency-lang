import { map } from "std::array"
def confirmItem(item: string): string {
  interrupt("approve ${item}?")
  return "confirmed: ${item}"
}

node main() {
  let results = fork(["a", "b"]) as item {
    return confirmItem(item)
  }
  const results2 = map(results) as result {
    if (isSuccess(result)) {
      return result.value
    } else {
      return { 
        success: false,
        error: result.error
      }
    }
  }
  return results2
}