import { map } from "std::array"
def riskyOp(label: string): string {
  interrupt("approve ${label}?")
  return "confirmed: ${label}"
}

node main() {
  handle {
    let results = fork(["allow", "deny"]) as item {
      return riskyOp(item)
    }
    const results2 = map(results) as result {
      if (isFailure(result)) {
        return { 
          success: false,
          error: result.error
        }
      }
      return result
    }
    return results2
  } with (interrupt) {
    if (interrupt.message == "approve deny?") {
      return reject()
    }
    return approve()
  }
}