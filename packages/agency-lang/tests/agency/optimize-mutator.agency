import node { mutatePrompt } from "../../lib/agents/optimize/mutatePrompt.agency"

type OptimizeMutationOperation = {
  target: string;
  kind: string;
  op: string;
  value: string;
  rationale: string
}

type OptimizeMutationProposal = {
  operations: OptimizeMutationOperation[];
  rationale: string
}

node main(): OptimizeMutationProposal {
  const targets = "- id: foo.agency:bar:prompt\n  kind: variable\n  current value: \"Classify: $" + "{text}\""
  const goals = "- [task-1] Improve classification accuracy"
  const proposal = mutatePrompt(
    targets,
    goals,
    "",
    "",
  )
  return proposal.data
}
