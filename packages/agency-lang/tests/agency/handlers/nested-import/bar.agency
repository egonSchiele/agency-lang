const log = []

def logWithAssign() {
  log.push("foo start")
  const val = interrupt("check")
  log.push(val)
  log.push("foo end")
  return "log return"
}

export def getLog() {
  return log
}

export def barHandler() {
  handle {
    const result = logWithAssign()
    if (isFailure(result)) {
      log.push(result.error)
    } else {
      log.push(result)
    }
  } with (data) {
    return approve()
  }
}