export safe def add(a: number, b: number): number {
  """
  Adds two numbers together.
  @param a - First number
  @param b - Second number
  """
  return a + b
}

export safe def greet(name: string): string {
  """Greets someone by name."""
  return "Hello, ${name}!"
}

def internal(): string {
  return "not exported"
}
