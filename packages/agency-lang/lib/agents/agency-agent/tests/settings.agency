/*
 * Tests for the agent's settings.json persistence layer.
 *
 * Each node sets up disk state inline (rather than relying on test
 * ordering) so cases are independent. `with approve` auto-approves the
 * fs interrupts that read/write/mkdir raise — the test is the user opt-in.
 */
import { remove } from "std::fs"

import { POLICY_DIR, SETTINGS_FILE, SETTINGS_PATH } from "../lib/config.agency"
import {
  loadSettings,
  saveSettings,
  sanitizeModelSettings,
  getModelSettings,
  getCapabilitySettings,
  ModelSettings,
 } from "../lib/settings.agency"

node roundTripsTheSearchBackend(): string {
  saveSettings({
    search: {
      backend: "tavily"
    }
  }) with approve
  const loaded = loadSettings() with approve
  const search = loaded.search
  if (search == null || search.backend == null) {
    return ""
  }
  return search.backend
}

node missingFileLoadsAsEmpty(): string {
  // Exercise the missing-file path: delete settings.json first.
  remove(SETTINGS_PATH) with approve
  const loaded = loadSettings() with approve
  if (loaded.search == null || loaded.search == undefined) {
    return "empty"
  }
  return "unexpected: ${loaded.search.backend}"
}

node corruptFileLoadsAsEmpty(): string {
  // Write garbage and confirm the parse failure is swallowed.
  write(SETTINGS_FILE, "not json{{{", POLICY_DIR) with approve
  const loaded = loadSettings() with approve
  if (loaded.search == null || loaded.search == undefined) {
    return "empty"
  }
  return "unexpected: ${loaded.search.backend}"
}

node dropsUnknownSlotKey(): ModelSettings {
  return sanitizeModelSettings(
    {
    slots: {
      reasoning: "opus",
      resoning: "typo"
    }
  },
  )
}

node doesNotMutateInput(): string {
  const input: ModelSettings = {
    slots: {
      reasoning: "opus",
      resoning: "typo"
    }
  }
  sanitizeModelSettings(input)
  if (input.slots["resoning"] == "typo") {
    return "unmutated"
  }
  return "MUTATED"
}

node roundTripsModelSlots(): string {
  saveSettings(
    {
    model: {
      slots: {
        reasoning: "claude-opus-4-8"
      }
    }
  },
  ) with approve
  const loaded = loadSettings() with approve
  return getModelSettings(loaded).slots["reasoning"]
}


node roundTripsCapabilities(): string {
  saveSettings({
    capabilities: {
      models: {
        "test-caps-model": {
          prompt: "large"
        }
      }
    }
  }) with approve
  const loaded = loadSettings() with approve
  const caps = getCapabilitySettings(loaded)
  const models = caps.models
  if (models == null) {
    return "missing"
  }
  const prompt = models["test-caps-model"].prompt
  if (prompt == null) {
    return "missing-prompt"
  }
  return prompt
}

node capabilitiesSanitizedOnLoad(): string {
  // Raw JSON, not a typed literal: unknown field + wrong-typed maxTokens,
  // exactly what a hand-edited settings.json can contain.
  write(
    SETTINGS_FILE,
    "{\"capabilities\":{\"global\":{\"prompt\":\"gigantic\",\"summarize\":false,\"maxTokens\":\"2000\",\"frobnicate\":true}}}",
    POLICY_DIR,
  ) with approve
  const loaded = loadSettings() with approve
  const caps = getCapabilitySettings(loaded)
  const globalPatch = caps.global
  if (globalPatch == null) {
    return "no-global"
  }
  return "${globalPatch.prompt}/${globalPatch.summarize}/${globalPatch.maxTokens}"
}

node missingCapabilitiesIsEmpty(): string {
  saveSettings({
    search: {
      backend: "off"
    }
  }) with approve
  const loaded = loadSettings() with approve
  const caps = getCapabilitySettings(loaded)
  if (caps.models == null && caps.providers == null && caps.global == null) {
    return "empty"
  }
  return "unexpected"
}

node nullEntryAndReservedKeySurviveLoad(): string {
  // A hand-edited file with a null entry used to throw inside
  // loadSettings (sanitizePatch read .prompt off null); a __proto__ key
  // would reparent the record on assignment instead of storing. Both
  // must be dropped with the valid sibling kept.
  write(
    SETTINGS_FILE,
    "{\"capabilities\":{\"models\":{\"broken\":null,\"__proto__\":{\"summarize\":false},\"ok\":{\"summarize\":true}}}}",
    POLICY_DIR,
  ) with approve
  const loaded = loadSettings() with approve
  const caps = getCapabilitySettings(loaded)
  const models = caps.models
  if (models == null) {
    return "no-models"
  }
  const okEntry = models["ok"]
  if (okEntry == null) {
    return "sibling-lost"
  }
  return "${models["broken"]}/${okEntry.summarize}"
}

node dropsBareEmbeddingSlotValue(): string {
  const cleaned = sanitizeModelSettings(
    {
    slots: {
      embedding: "text-embedding-3-small",
      reasoning: "opus"
    }
  },
  )
  const slots = cleaned.slots
  if (slots == null) {
    return "no-slots"
  }
  return "${slots["embedding"]}/${slots["reasoning"]}"
}

node keepsPrefixedEmbeddingSlotValue(): string {
  const cleaned = sanitizeModelSettings(
    {
    slots: {
      embedding: "openai/text-embedding-3-small"
    }
  },
  )
  const slots = cleaned.slots
  if (slots == null) {
    return "no-slots"
  }
  return "${slots["embedding"]}"
}
