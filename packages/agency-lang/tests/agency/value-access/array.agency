const users = [{
  name: "Alice",
  age: 30
}]

node main() {
  // index
  const name1 = users[0].name
  users[0].name = "Bob"
  const name2 = users[0].name

  // var for index
  users.push({
    name: "Charlie",
    age: 25
  })
  let i = 0
  const names = []
  while (i < users.length) {
    names.push(users[i].name)
    i = i + 1
  }

  // print(users[0 + 1].name)

  const obj = {
    x: 1
  }

  //print(users[obj.x].name)

  return {
    name1: name1,
    name2: name2,
    names: names
  }
}