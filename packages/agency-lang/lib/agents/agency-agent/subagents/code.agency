import { typecheck, parseAST } from "std::agency"
/*
 * Code subagent ŌĆö handles anything that touches code or the file
 * system: writing, editing, typechecking, running shell commands.
 *
 * Exports `codeAgent` (registered as a coordinator tool in
 * `agent.agency`) plus `codeSysPrompt` / `codeTools`. The Workspace
 * state lives here (not in `shared.agency`) because only the code
 * subagent uses file-system tools. Relative paths resolve against the
 * agent working directory
 * (`setAgentCwd`/`getAgentCwd`), which `agent.agency` pins to the user's
 * cwd at startup.
 */
import { todoWrite, todoList } from "std::agent"
import { codingAgent } from "std::agents/coding"
import { expertAgent } from "std::agents/expert"
import { verifierAgent } from "std::agents/verifier"
import { guidanceOrEmpty, renderGuidance } from "std::agents/lib/expertGuidance"
import { feedbackHasErrors as guidanceFeedbackHasErrors, renderFeedback as guidanceRenderFeedback } from "std::agents/lib/feedback"
import { plannerAgent } from "std::agents/planner"
import { edit } from "std::fs"
import {
  gitStatus,
  gitLog,
  gitDiff,
  gitShow,
  gitBranchList,
  gitRemoteList,
  gitBlame,
  gitStashList,
  gitAdd,
  gitCommit,
  gitCheckout,
  gitSwitch,
  gitBranchCreate,
  gitBranchDelete,
  gitStashPush,
  gitStashPop,
  gitRestore,
 } from "std::git"
import { setAgentCwd, getAgentCwd } from "std::index"
import { remember, recall, setMemoryId } from "std::memory"
import { exec, ls, glob, grep, bash } from "std::shell"
import { skillsDir, docsSkill } from "std::skills"
import { systemMessage } from "std::thread"

import { withWebSearch, getSearchBackend } from "../lib/search.agency"
import { getSlowModel, getSlowProvider } from "../shared.agency"
import { oracleAgent } from "./oracle.agency"
import {
  reviewWrittenFiles,
  renderFeedback,
  feedbackHasErrors,
 } from "./review.agency"
import { verify, renderGaps, unwrapVerdict } from "./verify.agency"


static const superpowersSkill = skillsDir("./skills/superpowers", "flat") with approve

static const docSkill = docsSkill("guide")
static const cliSkill = docsSkill("cli")
static const diagnosticsSkill = docsSkill("diagnostics")
static const stdlibSkill = docsSkill("stdlib")

export def agencyCli(args: string[]): any {
  """
  Run the `agency` CLI with the given arguments. Returns an object with
  `stdout`, `stderr`, and `exitCode` (same shape as `bash`). Use this for
  agency subcommands such as `parse`, `ast`, and `typecheck` ŌĆö e.g.
  agencyCli(["ast", "foo.agency"]) or agencyCli(["typecheck",
  "foo.agency"]). Arguments are passed directly to the executable (no
  shell interpretation), so they cannot be chained or redirected. The
  default agent policies auto-approve the read-only agency subcommands;
  other subcommands still prompt for approval. Prefer this over `bash`
  for running agency.

  @param args - CLI arguments, e.g. ["typecheck", "foo.agency"]. The
    first element is the subcommand.
  """
  return exec("agency", args, useAgentCwd: true)
}

/** Read a bundled prompt file, or "" when it cannot be read. The prompts
  ship with the agent, so a missing one means a packaging problem, not a
  runtime condition worth failing the turn over. */
def promptFile(filename: string): string {
  const contents = read(filename) with approve
  if (isFailure(contents)) {
    return ""
  }
  return contents.value
}

export static const codeSysPrompt = promptFile("../prompts/code.md")

// The file-system / shell tools are partially applied with
// `useAgentCwd: true` so that, as agent tools, they resolve relative
// paths against the agent working directory (pinned to the user's cwd at
// startup, changeable via setAgentCwd). The base functions default this
// to false, so non-agent callers are unaffected.
export static const codeTools: any[] = [
  setAgentCwd,
  getAgentCwd,
  read.partial(useAgentCwd: true),
  write.partial(useAgentCwd: true),
  edit.partial(useAgentCwd: true),
  ls.partial(useAgentCwd: true),
  glob.partial(useAgentCwd: true),
  grep.partial(useAgentCwd: true),
  bash.partial(useAgentCwd: true),
  gitStatus,
  gitLog,
  gitDiff,
  gitShow,
  gitBranchList,
  gitRemoteList,
  gitBlame,
  gitStashList,
  gitAdd,
  gitCommit,
  gitCheckout,
  gitSwitch,
  gitBranchCreate,
  gitBranchDelete,
  gitStashPush,
  gitStashPop,
  gitRestore,
  agencyCli,
  typecheck,
  parseAST,
  remember,
  recall,
  superpowersSkill,
  docSkill,
  cliSkill,
  diagnosticsSkill,
  stdlibSkill,
  todoWrite,
  todoList,
  oracleAgent,
]

// Appended to the system prompt only when a web-search backend is active
static const WEB_SEARCH_NOTE = """
You have **web search**. Use it directly whenever a task needs current or
external information ŌĆö a fact to verify, a library or API to check, a
dataset or leaderboard to consult. Do NOT ask the user to look things up,
and do NOT decline a task as "needs research / out of scope": search for
what you need and keep going."""

// Appended in one-shot / autonomous mode (`agency agent -p`)
static const ONE_SHOT_NOTE = promptFile("../prompts/oneShot.md")

// Set by `agent.agency` (`setCodeOneShot`) before the first dispatch when the
// run is non-interactive. Gates `ONE_SHOT_NOTE`.
let _oneShot = false

export def setCodeOneShot(oneShot: boolean) {
  _oneShot = oneShot
}

// only add system message the first time
let _first = true

static const ESCALATE_MAX_COST = $20.00
static const ESCALATE_MAX_TIME = 15m

type TriageResult = {
  path: "simple" | "complex";
  plan: string[]
}

def triage(task: string): TriageResult {
  const prompt = """
Classify this coding task. If it is a single, straightforward change, set path to "simple" and leave plan empty. If it is multi-part or needs decomposition, set path to "complex" and outline the plan in 2 to 4 short bullets.

<task>
${task}
</task>
"""

  const result: TriageResult = llm(prompt)
  return result
}

/** Pure routing decision, testable without the classifier: "planner" or "direct". */
export def routeFor(decision: TriageResult): string {
  return if decision.path == "complex" then "planner" else "direct"
}

def escalate(task: string, reason: string, plan: string): string {
  """
  Switch this task to plan-as-code: writes and runs a purpose-built agent for a
  multi-step task, showing you the plan first. Reach for this ONLY when the task
  genuinely needs a multi-step plan you cannot finish in a few direct edits. Do
  NOT use it for ordinary follow-ups. After it returns, REPORT its result; do not
  redo the work it already did.

  @param reason - why this task needs a multi-step plan.
  @param plan - your outline of the steps.
  """
  const planned = plannerAgent(
    task,
    context: reason,
    plan: plan,
    maxCost: ESCALATE_MAX_COST,
    maxTime: ESCALATE_MAX_TIME,
  )
  if (isFailure(planned)) {
    return "Planner stopped: ${planned.error}"
  }
  return planned.value
}

export def codeAgent(userMsg: string) {
  """
  This agent can help with all coding-related tasks,
  such as reading, writing, or editing code. It can also
  respond to questions about the Agency language,
  such as questions related to the Agency syntax or CLI tool.

  @param userMsg - a message describing what help is needed.
  """
  const originalUserMsg = userMsg
  // Triage: a multi-part task is delegated to plannerAgent (shows a plan, then
  // runs it) instead of the direct loop. Simple tasks fall through.
  const decision = triage(userMsg)
  if (routeFor(decision) == "planner") {
    // Complex tasks acquire domain expertise first, then solve with it, then
    // verify against the expert checklist. `escalate` (the mid-flight tool)
    // still uses plannerAgent.
    //
    // The expert consult runs once per task and sets the whole direction, so it
    // gets the slow/strong model (the oracle pattern). The solve loop stays on
    // the ambient model. Benchmarks that pin every slot to one model are
    // unaffected: getSlowModel() resolves to that same pinned model.
    const consult = expertAgent(
      userMsg,
      maxCost: ESCALATE_MAX_COST,
      maxTime: 5m,
      model: getSlowModel(),
      provider: getSlowProvider(),
    )
    const guidance = guidanceOrEmpty(consult)
    const solved = codingAgent(
      userMsg,
      context: renderGuidance(guidance),
      maxCost: ESCALATE_MAX_COST,
      maxTime: ESCALATE_MAX_TIME,
    )
    let summary = if isFailure(solved) then "Coding agent stopped: ${solved.error}" else solved.value
    // The expert checklist is authoritative acceptance criteria: verify the
    // work against it and give the solver one round to fix what failed.
    const checked = verifierAgent(
      userMsg,
      criteria: guidance.checklist,
      maxCost: $5.00,
      maxTime: 5m,
    )
    if (guidanceFeedbackHasErrors(checked)) {
      const fixMsg = """
${userMsg}

A strict review found these problems:

${guidanceRenderFeedback(checked)}

Fix each problem exactly.
"""
      const fixed = codingAgent(
        fixMsg,
        maxCost: ESCALATE_MAX_COST,
        maxTime: ESCALATE_MAX_TIME,
      )
      if (!isFailure(fixed)) {
        summary = fixed.value
      }
    }
    return summary
  }
  const tools = [...codeTools]
  // A "simple" task that turns out to need a plan can still switch mid-flight.
  tools.push(escalate.partial(task: userMsg))

  let hasErrorsFromFeedback = false
  let needsFix = false
  let verifyRounds = 0
  let iterations = 0
  // Declared per-call (was an implicit module global) so a value never
  // leaks between codeAgent invocations.
  let reply = ""
  // Per-call primer so the loop always runs at least once. Do NOT reuse
  // the module-level `_first` for this: `_first` persists across calls (it
  // gates the one-time system message on the resumed "code" thread), so
  // using it as the loop primer meant every call after the first skipped
  // the tool-enabled llm() entirely ŌĆö the agent appeared to "lose" its
  // tools on the second turn.
  let firstIteration = true
  // const doSummarize = getCapabilities().summarize
  thread(label: "code", session: "code") {
    setMemoryId("code")
    while ((hasErrorsFromFeedback || needsFix || firstIteration) && iterations < 5) {
      firstIteration = false
      iterations += 1
      if (_first) {
        // Compose the system prompt from the static base plus the
        // capabilities that are actually active this run.
        let sys = codeSysPrompt
        if (getSearchBackend() != "off") {
          sys = "${sys}\n\n${WEB_SEARCH_NOTE}"
        }
        if (_oneShot) {
          sys = "${sys}\n\n${ONE_SHOT_NOTE}"
        }
        systemMessage(sys)
        _first = false
      }
      reply = llm(
        userMsg,
        withWebSearch({
        memory: true,
        tools: tools
      }),
      )

      const feedback = reviewWrittenFiles() with approve
      hasErrorsFromFeedback = feedbackHasErrors(feedback)
      if (hasErrorsFromFeedback) {
        const rendered = renderFeedback(feedback)
        userMsg = """
        The last code had errors:

        ${rendered}

        Please fix the errors.
        """
      } else if (_oneShot && verifyRounds < 2) {
        const verdictResult = try verify(originalUserMsg)
        const verdict = unwrapVerdict(verdictResult)
        if (!verdict.satisfied) {
          userMsg = """
            Your work isn't complete yet. A fresh review found these gaps:

            <gaps>
            ${renderGaps(verdict.gaps)}
            </gaps>

            Fix each gap; your work will be re-verified.
            """
          needsFix = true
          verifyRounds += 1
        } else {
          needsFix = false
        }
      }
    }

    const formatPrompt = """
   Please format this response so it correctly addresses the user's question. Remove any extra text such as "this code now typechecks correctly" or "this code doesn't have any errors now".

   User message:
   ```
   ${originalUserMsg}
   ```

   Code agent response:
   ```
   ${reply}
   ```
   """

    const formattedReply = llm(formatPrompt)
  }
  return formattedReply
}
