def nextTwoPrimes(): number[] {
  return llm("What are the next 2 prime numbers after that?")
}

node main() {
  const msgs = thread {
    const res1: number[] = llm("What is the first prime number > 100?")
    const msgs2 = thread {
      const res2: number[] = nextTwoPrimes()
      const msgs3 = subthread {
        const res3: number[] = nextTwoPrimes()
      }
      const msgs4 = thread {
        const res4: number[] = nextTwoPrimes()
      }

    }
    const msgs5 = subthread {
      const res5: number[] = nextTwoPrimes()
      const msgs6 = subthread {
        const res6: number[] = nextTwoPrimes()
      }
      const msgs7 = thread {
        const res7: number[] = nextTwoPrimes()
      }

    }
  }

  return {
    msgs: msgs,
    msgs2: msgs2,
    msgs3: msgs3,
    msgs4: msgs4,
    msgs5: msgs5,
    msgs6: msgs6,
    msgs7: msgs7
  }
}