import { mkdir, copy, move, remove, edit } from "std::fs"
import { exists, bash } from "std::shell"
import { join } from "std::path"

node main() {
  const base = "/tmp/agency-fs-sandbox-test"

  handle {
    // Clean up from any previous run
    remove(base)

    // Create sandbox directory
    const mkdirResult = mkdir(base)
    if (isFailure(mkdirResult)) {
      return "mkdir failed"
    }

    // Create a test file using bash. printf is portable across `sh`
    // implementations (the underlying _bash uses `sh -c`, where `echo -n`
    // is non-portable: dash treats `-n` as a literal argument).
    const testFile = join(base, "hello.txt")
    bash("printf 'hello world' > " + testFile)

    // Verify file exists
    if (!exists(testFile)) {
      return "file not created"
    }

    // Edit the file. `edit` validates that filename is not absolute when
    // `dir` is specified (defaults to "."), so pass `dir` explicitly.
    const editResult = edit("hello.txt", "hello", "goodbye", false, base)
    if (isFailure(editResult)) {
      return "edit failed"
    }

    // Copy the file
    const copyDest = join(base, "hello-copy.txt")
    const copyResult = copy(testFile, copyDest)
    if (isFailure(copyResult)) {
      return "copy failed"
    }
    if (!exists(copyDest)) {
      return "copy dest missing"
    }

    // Move the copy
    const moveDest = join(base, "hello-moved.txt")
    const moveResult = move(copyDest, moveDest)
    if (isFailure(moveResult)) {
      return "move failed"
    }
    if (!exists(moveDest)) {
      return "move dest missing"
    }
    if (exists(copyDest)) {
      return "move src still exists"
    }

    // Clean up
    const removeResult = remove(base)
    if (isFailure(removeResult)) {
      return "remove failed"
    }
    if (exists(base)) {
      return "remove did not delete"
    }

    return "fs ok"
  } with (data) {
    return approve()
  }
}
