node main() {
  // Array destructuring
  let items = [10, 20, 30, 40, 50]
  let [a, b] = items
  let [first, _, third] = items
  let [head, ...rest] = items

  // Object destructuring
  let person = { name: "Bob", age: 30, city: "NY" }
  let { name, age } = person
  let { name: n, age: ageRenamed } = person
  let { name: n2, ...others } = person

  // Nested
  let loc = { coords: [11, 22] }
  let { coords: [x, y] } = loc

  return [a, b, first, third, head, rest, name, age, n, ageRenamed, n2, others.age, others.city, x, y]
}
