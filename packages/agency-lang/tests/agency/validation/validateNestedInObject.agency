import { isEmail } from "std::validators"

@validate(isEmail)
type Email = string

type Contact = {
  name: string,
  email: Email
}

node main() {
  const good: Contact! = { name: "Alice", email: "user@example.com" }
  const bad: Contact! = { name: "Bob", email: "not-an-email" }
  if (isSuccess(good)) {
    if (isFailure(bad)) {
      return good.value.email
    }
  }
  return "failed"
}
