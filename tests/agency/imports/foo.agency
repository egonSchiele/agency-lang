import tool { increment, getGlobal } from "./bar.agency"
import tool { ascii } from "./bar.agency"
import { bestSong } from "./funcs.js"
import node { bar } from "./bar.agency"

def bestSongTool(artist: string): string {
  """
  This tool returns the best song by a given artist.
  """
  return bestSong(artist)
}

node agencyImport() {
  uses ascii
  result: number[] = llm("Use the ascii tool to convert the string 'hello' to ASCII codes")
  return result
}

node jsImport() {
  uses bestSongTool
  result: string = llm("Use the bestSongTool to find the best song by the artist 'The Beatles'")
  return result
}

node nodeImport() {
  return bar("Alice")
}

// test that global vars with the same name in different files
// don't clobber each other
globalVar = 3
node testGlobalVarIsolation() {
  increment()
  increment()
  return interrupt("Interrupting after 2 increments")
  barGlobal = getGlobal()
  return { 
    globalVarInFoo: globalVar,
    globalVarInBar: barGlobal
  }
}