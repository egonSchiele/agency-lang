**/dist/*
**/node_modules/*
.*
# Explicit (also matched by the .* rule above): the incremental-build
# scratch dir — tsc buildinfo now, Stage A manifest later. Kept explicit
# so the intent survives if the broad dot-rule is ever narrowed.
.agency-build/
**/index.mts
**/__evaluate.*
**/__judge*
**/tests/**/*.evaluate.js
**/tests/**/*.evaluate.json
**/tests/**/*.judge.js
**/tests/**/*.judge_evaluate.js
**/tests/**/*.judge_evaluate.json
**/*.js
!**/test.js
# Stage-2 helper of the subprocess durability test (spawned by its test.js)
!**/tests/agency-js/subprocess-durable-resume/resume-stage.js
skills/*
*__result.json
**/docs/local/
docs-new/node_modules/*
stdlib/index.ts
stdlib/array.ts
stdlib/object.ts
stdlib/strategy.ts
**/traces/*
**/statelog.log
**/log.jsonl
tests/agency-js/**/traces/*
**/test-output/
**/test-frames/
# Compiled debugger test fixtures (generated by beforeAll in test files).
# Leading ** is load-bearing: a slash-containing pattern without it anchors
# to the repo root and silently misses packages/agency-lang/tests/debugger/
# (which is how six generated fixtures ended up tracked for months).
**/tests/debugger/*.ts

# Allow test fixture files for pkg:: import tests
!tests/pkg-imports/node_modules/
!tests/pkg-imports/node_modules/**
!tests/pkg-imports/node_modules/**/*.js
!**/docs-new/.vitepress
**/docs-new/.vitepress/dist
**/docs-new/.vitepress/cache
**/runs/
.agency-tmp/
tests/integration/statelog/.tmp/
# transient output from the optimizer efficacy harness (cleaned up on a
# clean pass; kept on failure or when OPTIMIZE_EFFICACY_KEEP_RUNS=1 for
# debugging real-LLM runs without re-spending tokens)
**/optimize-efficacy-runs-*/
