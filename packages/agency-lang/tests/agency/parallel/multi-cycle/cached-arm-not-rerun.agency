// Under per-branch globals isolation (see
// docs/superpowers/ideas/2026-06-04-per-thread-globals.md), a parallel
// arm's writes to a `global let` no longer leak back to the parent —
// each arm runs against its own snapshot clone. That breaks the
// original detection trick this test used (incrementing a shared
// counter and observing it in the parent). The cached arm's side
// effect now lands in the discarded clone whether the arm re-ran on
// resume or not.
//
// What this test verifies under the new semantics: the cached arm's
// return value is consistent across the resume cycle (i.e., the
// completed arm's `BranchState.result` is reused on resume, not
// recomputed). The asserted `counter:0` is also part of the contract
// — branch writes to `counter` never leak to the parent.

let counter = 0

def cachedArm(): string {
  counter = counter + 1
  return "n${counter}"
}

def interruptingArm(): string {
  const v = interrupt("approve?")
  return "ok"
}

node main() {
  parallel {
    let a = cachedArm()
    let b = interruptingArm()
  }
  return "${a},${b},counter:${counter}"
}
