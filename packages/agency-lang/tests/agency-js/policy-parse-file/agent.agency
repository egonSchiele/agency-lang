import { parsePolicyFile } from "std::policy"

node main(args: { policyFile: string, missingFile: string }) {
  // Existing valid file → loads.
  const p1 = parsePolicyFile(args.policyFile) with approve
  if (isFailure(p1)) { return "FAIL: existing file did not load" }
  if (keys(p1.value).length == 0) { return "FAIL: existing file did not load" }

  // Missing file → reports a typed failure.
  const p2 = parsePolicyFile(args.missingFile) with approve
  if (!isFailure(p2)) { return "FAIL: missing file should fail" }
  if (p2.error.status != "doesnt-exist") { return "FAIL: missing file status" }

  return "pass"
}
