node main() {
  // Basic for-of loop
  const items = ["a", "b", "c"]
  for (item in items) {
    print(item)
  }

  // Range-based for loop
  for (i in range(0, 5)) {
    print(i)
  }

  // Indexed for loop
  const names = ["alice", "bob"]
  for (name, index in names) {
    print(name)
    print(index)
  }
}
