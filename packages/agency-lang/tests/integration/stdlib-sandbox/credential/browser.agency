import { browserUse } from "std::browser"

node main() {
  handle {
    const result = browserUse(
      task: "Go to https://example.com and return the page title.",
      maxCostUsd: $1.00,
      timeout: 60s,
      allowedDomains: ["example.com"]
    )
    if (isFailure(result)) {
      return "browserUse failed: " + result.error
    }
    return "browser ok"
  } with (data) {
    return approve()
  }
}
