import { map } from "std::array"

// Basic agency functionality: auto-approve the read-only `agency`
// subcommands the code agent runs via the exec-based `agencyCli` tool.
// Matched on command + subcommand (no shell, so no chaining); other
// subcommands (run, compile, ...) still prompt.
static const AGENCY_SAFE_SUBCOMMANDS = [
  "parse",
  "ast",
  "typecheck",
  "tc",
  "help",
  "preprocess",
  "definition",
  "diagnostics",
  "doc",
  "literate",
]

def agencyExecApproveRules(): any[] {
  return map(AGENCY_SAFE_SUBCOMMANDS) as sub {
    return {
      match: {
        command: "agency",
        subcommand: sub
      },
      action: "approve"
    }
  }
}

export static const minimalAutoApprovePolicy = {
  "std::memory::remember": [{
    action: "approve"
  }],
  "std::memory::forget": [{
    action: "approve"
  }],
  "std::memory::recall": [{
    action: "approve"
  }],
  "std::memory::enableMemory": [{
    action: "approve"
  }],
  "std::memory::disableMemory": [{
    action: "approve"
  }],
  "std::exec": agencyExecApproveRules()
}

export static const recommendedAutoApprovePolicy = {
  ...minimalAutoApprovePolicy,
  "std::read": [{
    action: "approve"
  }],
  "std::readBinary": [{
    action: "approve"
  }],
  "std::ls": [{
    action: "approve"
  }],
  "std::glob": [{
    action: "approve"
  }],
  "std::grep": [{
    action: "approve"
  }],
  "std::wikipedia::search": [{
    action: "approve"
  }],
  "std::wikipedia::summary": [{
    action: "approve"
  }],
  "std::wikipedia::article": [{
    action: "approve"
  }],
  "std::weather": [{
    action: "approve"
  }],
  "std::search": [{
    action: "approve"
  }],
  "std::tavilySearch": [{
    action: "approve"
  }],
  "std::skills::skillsDir": [{
    action: "approve"
  }],
  "std::skills::commandsDir": [{
    action: "approve"
  }],
  "std::notify": [{
    action: "approve"
  }],
  "std::clipboardCopy": [{
    action: "approve"
  }],
  "std::git::status": [{
    action: "approve"
  }],
  "std::git::log": [{
    action: "approve"
  }],
  "std::git::diff": [{
    action: "approve"
  }],
  "std::git::show": [{
    action: "approve"
  }],
  "std::git::branchList": [{
    action: "approve"
  }],
  "std::git::remoteList": [{
    action: "approve"
  }],
  "std::git::blame": [{
    action: "approve"
  }],
  "std::git::stashList": [{
    action: "approve"
  }]
}

// Glob that matches a directory and everything under it. This is the
// same convention `std::policy`'s `buildScopedMatch` uses for the
// interactive "approve-always-here" rule: the exact path OR any nested
// path. `baseDir` must be absolute (the agent pins it to the launch cwd
// via `setAgentCwd(cwd())`), so relative paths the model passes resolve
// into this range and outside paths fall through to prompting.
def dirScope(baseDir: string): string {
  return "{${baseDir},${baseDir}/**}"
}

// `recommended` plus auto-approval of the mutating file-system and
// git-write effects, each scoped to `baseDir` and its children; anything
// outside still prompts. Matched on each effect's path field: `dir`
// (write/edit/mkdir), `target` (remove), `src`+`dest` (copy/move), `cwd`
// (git). Confinement is real: write/edit run `filename` through
// `resolvePath` (rejects `..`/absolute/`~`/symlink) and the scope glob
// won't match a `..`-containing path.
export def withWritesPolicy(baseDir: string) {
  const scope = dirScope(baseDir)
  const dirRule = [{ match: { dir: scope }, action: "approve" }]
  const cwdRule = [{ match: { cwd: scope }, action: "approve" }]
  return {
    ...recommendedAutoApprovePolicy,
    "std::write": dirRule,
    "std::writeBinary": dirRule,
    "std::edit": dirRule,
    "std::mkdir": dirRule,
    "std::remove": [{ match: { target: scope }, action: "approve" }],
    "std::copy": [{ match: { src: scope, dest: scope }, action: "approve" }],
    "std::move": [{ match: { src: scope, dest: scope }, action: "approve" }],
    "std::git::add": cwdRule,
    "std::git::commit": cwdRule,
    "std::git::checkout": cwdRule,
    "std::git::switch": cwdRule,
    "std::git::branchCreate": cwdRule,
    "std::git::branchDelete": cwdRule,
    "std::git::stashPush": cwdRule,
    "std::git::stashPop": cwdRule,
    "std::git::restore": cwdRule
  }
}

// `with-writes` plus auto-approval of `std::bash`, scoped to `baseDir`
// on the command's `cwd`. NOTE: a shell command can still reach outside
// `baseDir` via an absolute path or `cd` inside the command string —
// the policy matches the declared `cwd`, not the shell's actual effects,
// so this is best-effort confinement, not a hard sandbox. It exists so
// autonomous / sandbox runs (e.g. a benchmark container) can drive the
// shell without a human answering every approval.
export def withBashPolicy(baseDir: string) {
  const scope = dirScope(baseDir)
  return {
    ...withWritesPolicy(baseDir),
    "std::bash": [{ match: { cwd: scope }, action: "approve" }]
  }
}

// Built-in policy names accepted by the `--policy` flag (anything else
// is treated as a path to a policy JSON file).
export static const BUILTIN_POLICY_NAMES = [
  "recommended",
  "minimal",
  "with-writes",
  "with-bash",
]

// Resolve a built-in policy name to a concrete `Policy`, scoping the
// cwd-relative variants to `baseDir`. Returns null for an unknown name
// so the caller can fall back to treating the argument as a file path.
export def builtinPolicy(name: string, baseDir: string) {
  if (name == "minimal") {
    return minimalAutoApprovePolicy
  }
  if (name == "recommended") {
    return recommendedAutoApprovePolicy
  }
  if (name == "with-writes") {
    return withWritesPolicy(baseDir)
  }
  if (name == "with-bash") {
    return withBashPolicy(baseDir)
  }
  return null
}
