def run(b: () -> void) {
  b()
}

def addTwo(a: number, b: number): number {
  return a + b
}

node main(): number {
  let result = 0
  run() as {
    // `add5` is a block-local variable holding a function (a partial
    // application). Calling it must resolve the callee to the block
    // frame, not emit a bare `add5` (which is a ReferenceError).
    let add5 = addTwo.partial(a: 5)
    result = add5(10)
  }
  return result
}
