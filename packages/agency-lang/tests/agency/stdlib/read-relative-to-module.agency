node main() {
  // `__dirname` names this .agency file's directory, so the fixture
  // beside this file resolves no matter where the program was run
  // from. `with approve` auto-approves the interrupt `read()` raises.
  let result = read("read-relative-to-module-fixture.txt", __dirname) with approve
  if (result is success(content)) {
    return { ok: true, content: content }
  }
  return { ok: false }
}
