// Project Euler Problem 9: Special Pythagorean Triplet
// Find the product abc where a + b + c = 1000 and a^2 + b^2 = c^2.

node main() {
  let a = 1
  while (a < 1000) {
    let b = a + 1
    while (b < 1000 - a) {
      let c = 1000 - a - b
      if (a * a + b * b == c * c) {
        return a * b * c
      }
      b = b + 1
    }
    a = a + 1
  }
  return 0
}
