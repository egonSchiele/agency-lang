def getWeather(city: string): string {
  return fetch("https://weather.example.com/${city}")
}

def formatTemp(temp: number): string {
  return "${temp} degrees"
}

node main() {
  const forecast: string = llm("What is the weather in NYC?", { tools: [getWeather, formatTemp] })
  const summary: string = llm("Summarize the forecast")
}