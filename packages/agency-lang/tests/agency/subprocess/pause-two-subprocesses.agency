import { compile, run } from "std::agency"

// Two concurrent subprocesses (one per fork branch) both pause. Their
// interrupts batch into ONE surfaced array; one respond resumes both
// children independently. Also proves the per-call payload frames do not
// collide across concurrent run() calls.
node main() {
  const source = """
import { bash } from "std::shell"
node main(tag: string) {
  let r = bash("echo sub-" + tag)
  return r.stdout
}
"""
  const compileResult = compile(source)
  if (isFailure(compileResult)) {
    return "compile failed"
  }
  const compiled = compileResult.value
  handle {
    const results = fork(["a", "b"]) as item {
      const result = run(compiled: compiled, node: "main", args: { tag: item })
      if (isSuccess(result)) {
        return result.value.data
      }
      return "run failed"
    }
    return results
  } with (e) {
    if (e.effect == "std::run") {
      return approve()
    }
  }
}
