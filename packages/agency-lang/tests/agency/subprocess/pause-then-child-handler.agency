import { compile, run } from "std::agency"

// After a pause/resume, the CHILD must re-register its own handlers during
// replay before the next interrupt site resolves. The first bash is
// unhandled (pauses); the second must be approved by the child-local
// handler — if that handler were skipped after resume, the second bash
// would surface a second interrupt and the single-response test would fail.
node main() {
  const source = """
import { bash } from "std::shell"
node main() {
  let first = bash("echo unhandled-one")
  handle {
    let second = bash("echo handled-two")
    return first.stdout + second.stdout
  } with (e) {
    return approve()
  }
}
"""
  const compileResult = compile(source)
  if (isFailure(compileResult)) {
    return "compile failed"
  }
  handle {
    const result = run(compiled: compileResult.value, node: "main")
    if (isSuccess(result)) {
      return result.value.data
    }
    return "run failed"
  } with (e) {
    if (e.effect == "std::run") {
      return approve()
    }
  }
}
