import { search } from "std::wikipedia"

def callMe(block) {
  return block()
}

node main() {
  match(event) {
    // you can now use the `x` and `y` variables in the arm body
    { type: "click", x, y } => handleClick(x, y)
    { type: "scroll", delta } => handleScroll(delta)
    _ => ignore()
  }
}
