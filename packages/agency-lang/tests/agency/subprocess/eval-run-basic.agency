import { compile } from "std::agency"
import { evalRun } from "std::agency/eval"

node main() {
  const source = "node main() { return 42 }"
  const compileResult = compile(source)
  if (isFailure(compileResult)) {
    return "compile failed"
  }

  handle {
    const result = evalRun(
      compiled: compileResult.value,
      inputs: [{ id: "t1", goal: "returns 42", args: {} }],
      runsDir: "/tmp/agency-eval-run-basic",
      runId: "r1",
    )
    return result.okCount == 1 && result.errorCount == 0
  } with (data) {
    return approve()
  }
}
