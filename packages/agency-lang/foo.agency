import { remember, recall } from "std::memory"
def greet(name: string): string {
  return "Hello, ${name}!"
}

node main() {
  const name = "Alice"
  const greeting = llm("Greet ${name} using the greet tool", {
    tools: [greet]
  })
  print(greeting)
  remember("Maggie loves weaving")
  const memory = recall("Maggie loves weaving")
  print(memory)
}
