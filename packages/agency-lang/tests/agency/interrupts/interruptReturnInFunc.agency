def greet(name: string): string {
  return interrupt("Are you sure you want to greet someone?")
  return "Kya chal raha jai, ${name}!"
}

node foo() {
  const greeting = greet("AI World")
  return { 
    greeting: greeting
  }
}

// also testing going to a second node
// this catches a regression where gotonode
// calls weren't popping a frame off the stack first
node bar() {
  return foo()
}