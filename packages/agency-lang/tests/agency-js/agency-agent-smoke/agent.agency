// Smoke test for the agency-agent REPL plumbing. We stub out
// `route()` (no LLM call) and drive the repl() widget with a
// scripted key sequence to confirm:
//   - Plain user messages flow through `onSubmit` and land in the
//     transcript via `output()`.
//   - The slash-command palette opens on "/", filters as the user
//     types, and Enter selects the highlighted entry into the
//     input buffer (without submitting).
//   - A submitted "/exit" causes onSubmit to return false, which
//     terminates the loop cleanly.
import { repl, setScriptedKeys } from "std::ui"

let lines: string[] = []
def out(): string[] { return lines }
def stat(): { left: string, right: string } { return { left: "smoke", right: "" } }
def onSub(msg: string): boolean {
  if (msg == "/exit") { return false }
  lines.push("echo: ${msg}")
  return true
}

node main(): string {
  // Sequence:
  //   "h","i",enter        → submit "hi" → lines becomes ["echo: hi"]
  //   "/","e","x","i","t"  → palette opens, filter narrows to "/exit"
  //   enter                → palette selects "/exit" into buffer
  //   enter                → submit "/exit" → onSubmit returns false, exit
  setScriptedKeys([
    { key: "h" }, { key: "i" }, { key: "enter" },
    { key: "/" }, { key: "e" }, { key: "x" }, { key: "i" }, { key: "t" },
    { key: "enter" }, { key: "enter" }
  ])
  repl(prompt: "> ", output: out, status: stat,
       paletteCommands: { "/exit": "Exit" }, onSubmit: onSub)
  if (lines.length != 1)      { return "FAIL: ${lines.length} lines" }
  if (lines[0] != "echo: hi") { return "FAIL: ${lines[0]}" }
  return "pass"
}
