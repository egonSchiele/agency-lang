import { guard } from "std::thread"

node main() {
  const r1 = guard(cost: 0.000001) as {
    saveDraft("g1-draft")
    const a = llm("Reply with: pong")
    return a
  }
  const r2 = guard(cost: 0.000001) as {
    const b = llm("Reply with: pong")
    return b
  }
  let first = "?"
  if (isSuccess(r1)) { first = r1.value }
  return "${first}|${isFailure(r2)}"
}
