import { copy } from "std::fs"

node main() {
  let badDest = copy("tests/agency/stdlib/glob-fixtures/a.md", "/") with approve
  let topDest = copy("tests/agency/stdlib/glob-fixtures/a.md", "/tmp") with approve
  return {
    rootDestRefused: isFailure(badDest),
    topDestRefused: isFailure(topDest)
  }
}
