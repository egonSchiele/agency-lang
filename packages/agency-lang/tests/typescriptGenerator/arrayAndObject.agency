// Test arrays and objects

// Simple array
const nums: number[] = [1, 2, 3, 4, 5]
print(nums)

// Array with strings
const names: string[] = ["Alice", "Bob", "Charlie"]
print(names)

// Nested arrays
const matrix: number[][] = [[1, 2], [3, 4], [5, 6]]
print(matrix)

// Simple object
const person: { name: string; age: number } = {name: "Alice", age: 30}
print(person)

// Object with nested structure
const address: { street: string; city: string; zip: string } = {street: "123 Main St", city: "NYC", zip: "10001"}
print(address)

// Object with array property
const user: { name: string; tags: string[] } = {name: "Bob", tags: ["admin", "developer"]}
print(user)

// Array of objects
const users: { name: string; age: number }[] = [{name: "Alice", age: 30}, {name: "Bob", age: 25}]
print(users)

// Nested object
const config: { server: { host: string; port: number }; debug: boolean } = {server: {host: "localhost", port: 8080}, debug: true}
print(config)

// Array access
const firstNum = nums[0]
print(firstNum)

// Object property access
const personName = person.name
print(personName)
