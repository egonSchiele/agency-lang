node main() {
  const msgs = thread {
    const res1: number[] = llm("What are the first 5 prime numbers?")
    const res2: number[] = llm("What are the next 2 prime numbers after those?")
    const msgs2 = subthread {
      const res3: number = llm("And what are the next two integers after those?")
    }
    const msgs3 = subthread {
      const res4: number = llm("What are the next 3 after that?")
    }
  }
  return [msgs, msgs2, msgs3]
}