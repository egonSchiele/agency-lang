def add(x: number, y: number): number {
  """
  Adds two numbers together
  """
  const result: number = llm("add ${x} and ${y}")
  return result
}

def greet(name: string) {
  """
  Greets a person by name
  """
  const message = llm("Hello ${name}!")
  return message
}

def mixed(count: number, label) {
  """
  Mixed typed and untyped parameters
  """
  const output = llm("${label}: ${count}")
  return output
}

def processArray(items: number[]) {
  """
  Processes an array of numbers
  """
  const result = llm("Processing array with ${items} items")
  return result
}

def flexible(value: string | number) {
  """
  Handles either a string or number
  """
  const result = llm("Received value: ${value}")
  return result
}

node foo(): string {
  print("This is a node with a return type")
  return "Node completed"
}

node main() {
  // Call the functions
  const sum = add(5, 10)
  const greeting = greet("Alice")
  const labeled = mixed(42, "Answer")
  const processed = processArray([1, 2, 3, 4, 5])
  const flexResult = flexible("test")
}