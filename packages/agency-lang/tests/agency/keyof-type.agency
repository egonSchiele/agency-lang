// keyof produces a closed key union; the schema accepts real keys and
// rejects anything else. (Schema bound to a variable first — #480.)
type User = {
  name: string,
  age: number,
}

node accepts() {
  const s = schema(keyof User)
  const r = s.parseJSON("\"name\"")
  if (isSuccess(r)) {
    return r.value
  }
  return "parse failed"
}

node rejects() {
  const s = schema(keyof User)
  const r = s.parseJSON("\"email\"")
  if (isFailure(r)) {
    return "rejected"
  }
  return "accepted"
}
