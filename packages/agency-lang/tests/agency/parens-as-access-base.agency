// Regression test: a parenthesized expression must be a valid head of
// an access chain (`.field`, `[i]`, `.method()`). Previously the parser
// did not recognize chain elements after `)`, so `(s).length` silently
// became `let n = (s)` followed by a stray `length` statement.
//
// The original fixture exercised `(new Counter(5)).bump()` and
// `(makeCounter(10)).bump()` against a `class Counter`. Classes were
// removed; we now use a plain-object Counter whose `bump` is a closure
// over the start value. The parens-as-head-of-chain coverage is the
// same — only the receiver flavor changed.

type Counter = {
  n: number,
  bump: () => number
}

def bumpFrom(start: number): number {
  return start + 1
}

def makeCounter(start: number): Counter {
  return {
    n: start,
    bump: bumpFrom.partial(start: start)
  }
}

node main(): number[] {
  let s = "hello"
  let arr = [10, 20, 30]
  let a = 1
  let b = 2

  // (var).field
  let len1 = (s).length
  // (binop).field
  let len2 = ("foo" + "bar").length
  // (var)[i]
  let first = (arr)[0]
  // (var)[expr]
  let second = (arr)[0 + 1]
  // (binop)[i] — index into the result of a string concatenation
  let charCode = ("ab" + "cd")[2].charCodeAt(0)
  // (objectLiteral-via-call).method()
  let bumped = (makeCounter(5)).bump()
  // (call()).method() — separate variable to exercise the call-then-method shape twice
  let bumped2 = (makeCounter(10)).bump()

  return [len1, len2, first, second, charCode, bumped, bumped2]
}
