import { route } from "std::agent"

def codeOnly(): string { return "edited" }
def researchOnly(): string { return "found" }

node main(): string {
  const reply = route({
    start: "code",
    agents: {
      code:     { systemPrompt: "code agent", tools: [codeOnly] },
      research: { systemPrompt: "research agent", tools: [researchOnly] },
    },
    maxHops: 3,
  }, "look up X")
  return reply
}
