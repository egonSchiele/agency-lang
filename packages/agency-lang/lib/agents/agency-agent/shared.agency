/*
 * Shared bootstrap for the Agency Agent.
 *
 * Sole responsibilities:
 *   - Compute the per-user state directory `$HOME/.agency-agent`.
 *   - Enable persistent memory so each subagent's `remember`/`recall`
 *     calls land in a stable on-disk knowledge graph.
 *
 * Routing + handoff used to live here; those moved to `std::agent`'s
 * `route()` / `handoff()` and the agent now consumes them directly.
 */
import { registerLocalModel } from "std::agency/local"
import { keys } from "std::object"
import { setLlmOptions } from "std::llm"
import { enableMemory } from "std::memory"
import { env } from "std::system"

import { resolveDetected, knownProviders, Resolved } from "./lib/models.agency"
import { resolveAll, buildLayers, Ctx } from "./lib/resolution.agency"
import { getModelSettings, loadSettings } from "./lib/settings.agency"
import { slotKind } from "./lib/slots.agency"


// Per-user state directory for the agent (persistent memory + saved
// policy). We expand `~` ourselves via `env("HOME")` because
// `enableMemory(...)`'s underlying `MemoryFrame` calls
// `path.resolve(cwd, dir)` directly — Node's `path.resolve` does NOT
// expand `~`, so passing `"~/.agency-agent/memory"` would silently
// create a literal `./~/.agency-agent/memory` under cwd instead of
// the intended `$HOME/.agency-agent/memory`. Tracked upstream as
// agency-lang#230. Falls back to `.` if `HOME` is unset (rare; mostly
// a Windows concern — the `.` puts the dir under cwd as a last
// resort instead of crashing module init).
def computeAgentDir(): string {
  const home = env("HOME")
  if (home == null) {
    return "./.agency-agent"
  }
  return "${home}/.agency-agent"
}

export static const AGENCY_AGENT_DIR = computeAgentDir()

// Persistent knowledge graph for every subagent. `setMemoryId(...)`
// (called inside std::agent's router) scopes which graph their
// `remember`/`recall` calls hit, so a single shared on-disk directory
// cleanly hosts both. `main()` calls this once, AFTER resolving the model,
// so it can be skipped for `--local-model`: the llama-cpp provider has no
// embedding endpoint, so enabling memory would only emit a one-time
// "Tier-2 disabled" notice and add overhead. All `std::memory` calls
// (`setMemoryId`/`recall`/`remember`) no-op when memory isn't enabled, so a
// local run works fine without it. Calling `enableMemory(...)` from `main()`
// is the documented pattern (see `stdlib/memory.agency`); `with approve`
// auto-approves the dir creation and has the enclosing step path it needs
// inside this def. We deliberately do NOT pin `embeddings.model`: for hosted
// providers the memory layer derives it from the active LLM provider
// (openai → text-embedding-3-small, google → text-embedding-004,
// ollama → nomic-embed-text). Set `embeddings.model` explicitly to override.
export def enableAgentMemory() {
  enableMemory({
    dir: "${AGENCY_AGENT_DIR}/memory"
  }) with approve
}

// The slow ("deep reasoning") model + its provider, set once by
// `configureModels()`. The deep subagents (oracle, explorer) read these.
// An empty slowProvider means "let smoltalk resolve the provider from
// the model name".
let slowModel: string = "gpt-5.5"
let slowProvider: string = "openai-responses"

export def getSlowModel(): string {
  return slowModel
}

export def getSlowProvider(): string {
  return slowProvider
}

// Cache of the last applied assignment, for getResolvedSlots() (the explain
// view + tests) and the cross-provider switch diff.
let _resolved: Record<string, Resolved> = {}

export def setSlowModel(name: string, provider: string) {
  slowModel = name
  slowProvider = provider
}

// The agent always uses the OpenAI Responses API (for hosted web_search), so
// any resolved `openai` provider is promoted to `openai-responses`. The built-in
// defaults already carry this (via planModels); this also covers the
// --model/--provider override paths. Idempotent.
def promoteProvider(provider: string): string {
  if (provider == "openai") {
    return "openai-responses"
  }
  return provider
}

export def promoteAll(
  slots: Record<string, Resolved>,
): Record<string, Resolved> {
  let promoted: Record<string, Resolved> = {}
  for (slot in Object.keys(slots)) {
    const resolved = slots[slot]
    if (resolved == null) {
      continue
    }
    promoted[slot] = {
      model: resolved.model,
      provider: promoteProvider(resolved.provider),
      via: resolved.via
    }
  }
  return promoted
}

/** Apply a resolved assignment. Dispatch on SLOT_KIND so adding a slot is a
  data edit, not another branch. `derived` (embedding) is a deliberate no-op —
  memory derives its own embed model from the active provider. Caches the
  applied slots for getResolvedSlots(). */
export def applyResolved(slots: Record<string, Resolved>) {
  _resolved = slots
  for (slot in Object.keys(slots)) {
    const resolved = slots[slot]
    if (resolved == null) {
      continue
    }
    const kind = slotKind(slot)
    if (kind == "fast") {
      setLlmOptions(
        {
        model: resolved.model,
        provider: resolved.provider
      },
      )
    } else if (kind == "slow") {
      setSlowModel(resolved.model, resolved.provider)
    }
  }
}

export def getResolvedSlots(): Record<string, Resolved> {
  return _resolved
}

export def currentProvider(): string {
  const main = _resolved["main"]
  if (main != null) {
    return main.provider
  }
  return slowProvider
}

/** Resolve and apply the agent's models from CLI flag values (each
 *  already normalized to "" when absent). The fast model becomes the
 *  run-wide default; the slow model is stored for the deep subagents.
 *  Explicit model flags win; an explicit `--provider` for a recognized
 *  provider selects that provider's default models and skips env
 *  auto-detection; otherwise a provider is detected from API-key env
 *  vars. Exits the process with a printed message on any unresolvable
 *  combination (no key, missing key for a forced provider, or a custom
 *  `--provider` with no model). Resolution logic lives in
 *  `lib/models.agency`; this shell just applies the result. */
export def configureModels(
  model: string,
  fast: string,
  slow: string,
  provider: string,
) {
  const settings = getModelSettings(loadSettings())

  // A saved provider preference (settings.model.provider) acts like --provider
  // (a forced provider that skips env auto-detection); an explicit --provider
  // still wins, and env auto-detection is the fallback when neither is set.
  let effectiveProvider = provider
  if (effectiveProvider == "" && settings.provider != null && settings.provider != "") {
    effectiveProvider = settings.provider
  }

  const detected = resolveDetected(model, fast, slow, effectiveProvider)
  if (isFailure(detected)) {
    print(detected.error)
    process.exit(1)
    return
  }

  // CLI flags become layers: --model is a global pin; --fastmodel/--slowmodel
  // are per-slot overrides. Settings (settings.json model.slots/pin) sit below
  // CLI. The built-in price-default fills anything unset. See spec 3.3.
  const ctx: Ctx = {
    provider: detected.value,
    price: "standard"
  }
  let cliSlots: Record<string, string> = {}
  if (fast != "") {
    cliSlots["main"] = fast
  }
  if (slow != "") {
    cliSlots["reasoning"] = slow
  }

  // providerEstablished is true when a provider is fixed (CLI or settings) so
  // parseModelSpec will not split a unified provider/model and override it.
  const providerEstablished = effectiveProvider != ""
  const layers = buildLayers(
    "",
    {},
    model,
    cliSlots,
    settings,
    knownProviders(),
    providerEstablished,
  )
  const all = resolveAll(layers, ctx)
  if (isFailure(all)) {
    print(all.error)
    process.exit(1)
    return
  }
  applyResolved(promoteAll(all.value))
}

/** Apply a local model (from `--local-model`) as BOTH the fast and slow
 *  model: register the llama-cpp provider, download the model if needed into
 *  the agent's models cache, and point every LLM call — including the deep
 *  subagents — at it, so a fully-local run needs no hosted-provider key. */
export def configureLocalModel(value: string) {
  // `try` captures any failure (smoltalk-llama-cpp not installed, an unknown
  // model name, a download error) as a Result instead of letting the runtime
  // convert the throw to a Failure and silently continue into the REPL. A
  // local-model setup failure is fatal: print it and exit, mirroring how
  // `configureModels` exits on an unresolvable provider.
  // No explicit cache dir: use the shared default (AGENCY_MODELS_DIR env,
  // else agency.json client.modelsDir, else ~/.agency-agent/models) so a CLI
  // `agency local download` and the agent reuse the same downloaded models.
  const result = try registerLocalModel(value)
  if (isFailure(result)) {
    print(result.error)
    process.exit(1)
    return
  }
  const modelPath = result.value
  // Local pins every slot to the one llama-cpp model. Route through
  // applyResolved so getResolvedSlots() reflects it (the explain view + the
  // /local recall diff). Embedding is empty — llama-cpp has no embed endpoint.
  const r: Resolved = {
    model: modelPath,
    provider: "llama-cpp",
    via: "local"
  }
  applyResolved(
    {
    main: r,
    reasoning: r,
    embedding: {
      model: "",
      provider: "llama-cpp",
      via: "local"
    }
  },
  )
}

