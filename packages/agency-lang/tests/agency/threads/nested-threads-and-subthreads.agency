node main() {
  const msgs = thread {
    const res1: number[] = llm("What is the first prime number > 100?")
    const msgs2 = thread {
      const res2: number[] = llm("What are the next 2 prime numbers after that?")
    }
    const msgs3 = subthread {
      const res3: number[] = llm("What are the next 2 prime numbers after that?")
    }
  }

  return [msgs, msgs2, msgs3]
}