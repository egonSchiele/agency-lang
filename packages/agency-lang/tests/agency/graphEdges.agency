node classify(message: string) {
  const category: "greeting" | "farewell" = llm("Classify as 'greeting' or 'farewell': '${message}'")
  if (category == "greeting") {
    return respondGreeting()
  }
  if (category == "farewell") {
    return respondFarewell()
  }
  return "unknown"
}

node respondGreeting() {
  return "hello"
}

node respondFarewell() {
  return "goodbye"
}
