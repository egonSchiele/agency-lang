// Historical note: this fixture originally pinned the OPPOSITE — a
// top-level `callback("onThreadEnd")` in an IMPORTED module did NOT
// fire (PR #225 fix #8), which is why `lib/stdlib/threads.ts`
// registers its onThreadEnd snapshotter via `registerGlobalHook(...)`
// instead of a top-level Agency-side `callback(...)`. The
// cross-module callback registry fixed that hole, so the fixture now
// pins the positive: imported-module callbacks fire exactly like
// entry-module ones (see `tests/agency-js/entry-module-callback-fires/`
// for the entry-module direction).
import { setMutable } from "../../helpers/mutableVar.js"

callback("onThreadEnd") as evt {
  setMutable("imported-onThreadEnd-fired", true)
  setMutable("imported-onThreadEnd-thread-id", evt.threadId)
}

export def noop(): number {
  return 1
}
