
node main() {
  const result = guard(time: 500ms) {
    saveDraft("pre-interrupt")
    interrupt("continue?")      // pause; harness approves → resume
    sleep(2000)                 // after resume, exceed 500ms → trip
    return "done"
  }
  if (isFailure(result)) { return "unexpected" }
  return result.value
}
