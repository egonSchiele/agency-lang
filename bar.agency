def greet(name: string): string {
  return interrupt("Agent wants to call the greet function with name: ${name}")
  return "Kya chal raha jai, ${name}!"
}

node sayHi() {
  name = "foo"
  print("Saying hi to ${name}...")
  response = greet(name)
  print(response)
  print("Greeting sent.")
  return response
}