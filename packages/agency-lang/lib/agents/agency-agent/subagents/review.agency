import {
  review as agencyReview,
  mergeFeedback,
  renderFeedback as stdRenderFeedback,
  feedbackHasErrors as stdFeedbackHasErrors,
 } from "std::agency"
import { setMemoryId } from "std::memory"
import { gitStatus, gitIsRepo } from "std::git"
import { filter, map } from "std::array"

// The review core (parse + typecheck findings, optional LLM code-vs-task
// judgment, rendering helpers) lives in std::agency now — this subagent
// only owns the agent-shaped wrapper: extracting snippets from a chat
// message and reviewing each one. Consumers keep importing the shared
// surface from this module via the type + thin wrappers below.
//
// NOT `export { ... } from "std::agency"`: re-exporting the Feedback
// type alongside functions whose tool schemas reference it generates
// `const Feedback = _reexport_Feedback` AFTER the tool registrations
// that use it, so importing the compiled module throws "Cannot access
// Feedback before initialization" (pre-existing codegen ordering bug;
// same TDZ family as the prelude-wrapped stdlib re-export carve-outs).

/** Structurally identical to std::agency Feedback. */
export type Feedback = {
  error: boolean;
  feedback: string;
  data?: any
}

export def renderFeedback(feedback: Result<Feedback[]>): string {
  return stdRenderFeedback(feedback)
}

export def feedbackHasErrors(feedback: Result<Feedback[]>): boolean {
  return stdFeedbackHasErrors(feedback)
}

type AgencyCode = {
  code: string
}

export def reviewAgent(userMsg: string): string {
  """
  This agent can review any code written in the agency language.
  It can provide feedback on syntax errors, type errors, and best practices.

  @param userMsg - a message describing the code to review or the help needed.
  """
  const feedbackResult = review(userMsg)
  return renderFeedback(feedbackResult)
}

export def review(userMsg: string): Result<Feedback[]> {
  thread(label: "review", summarize: true, session: "review") {
    setMemoryId("review")

    const snippets: AgencyCode[] = llm(
      `Extract any Agency code snippets from the following message: ${userMsg}`,
    )

    let feedback: Result<Feedback[]> = success([])

    for (codeSnippet in snippets) {
      feedback = mergeFeedback(feedback, agencyReview(codeSnippet.code))
    }
  }
  return feedback
}

// ---- The code agent's auto-review: review the .agency FILES it wrote, not
// the model's chat reply. Feeding a Python/shell chat reply to the Agency
// parser crashed and mis-fired as "your code has errors", which thrashed the
// agent and shadowed the `verify` step. Reviewing on-disk .agency files means
// the parser only ever sees Agency source, so a non-Agency task is a clean
// no-op (empty findings) and the loop falls through to `verify`.

/** Keep only the .agency files from a list of paths. */
export def filterAgencyPaths(paths: string[]): string[] {
  return filter(paths, \path -> path.endsWith(".agency"))
}

/** The .agency files changed in the agent working directory, or [] when the
  working dir is not a git repo (or git otherwise fails). Fails open — a
  non-repo/error yields no files so the auto-review is a no-op, never a crash.
  Includes untracked new files (they are what a coding agent just wrote). */
export def changedAgencyFiles(): string[] raises <std::git::status> {
  // The auto-review only makes sense in a git repo. Skip it explicitly when the
  // working directory is not one (the common case — the agent often runs in a
  // plain dir), so review is a clean no-op rather than a caught git failure.
  if (!gitIsRepo()) {
    return []
  }
  // `try` still folds any other git failure to a Result we read as "no changed
  // files". The interrupt propagates to the caller's handler (the agent policy
  // auto-approves this read effect).
  const statusResult = try gitStatus()
  if (statusResult is success(status)) {
    return filterAgencyPaths(map(status.entries, \entry -> entry.path))
  }
  return []
}

/** Review the .agency source at each given path, merging the findings. Reads
  each file against the agent cwd; an unreadable path (e.g. a file `git status`
  lists as deleted) is skipped, so a stale path can never crash the review. No
  `task` is passed, so this is deterministic parse+typecheck with no LLM call. */
export def reviewFiles(paths: string[]): Result<Feedback[]> raises <std::read> {
  let feedback: Result<Feedback[]> = success([])
  for (path in paths) {
    const sourceResult = read(filename: path, useAgentCwd: true)
    if (sourceResult is success(source)) {
      feedback = mergeFeedback(feedback, agencyReview(source))
    }
  }
  return feedback
}

/** The code agent's per-iteration auto-review. Reviews the .agency files the
  agent changed this run (found via std::git), never the chat reply. Returns
  success([]) when no .agency files changed — the common case for Python / C /
  shell tasks — so `feedbackHasErrors` is false and the loop reaches `verify`. */
export def reviewWrittenFiles(): Result<Feedback[]> raises <std::git::status, std::read> {
  return reviewFiles(changedAgencyFiles())
}
