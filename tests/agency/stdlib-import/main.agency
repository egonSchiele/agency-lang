import { add, multiply } from "std::math"

node testStdlibAdd() {
  return add(3, 4)
}

node testStdlibMultiply() {
  return multiply(5, 6)
}

node testImplicitRound() {
  return round(3.14159, 2)
}

node testRoundAsTool() {
  uses round
  const result: number = llm("Use the round tool to round the number 2.71828 to 3 decimal places. Return only the rounded number.")
  return result
}
