def riskyOp(label: string): string {
  interrupt("approve ${label}?")
  return "confirmed: ${label}"
}

node main() {
  handle {
    let results = fork(["allow", "deny"]) as item {
      return riskyOp(item)
    }
    return results
  } with (data) {
    if (data == "approve deny?") {
      return reject()
    }
    return approve()
  }
}
