node main() {
  // Test match blocks (pattern matching)

  // Simple match with string literals
  const action = "start"
  match(action) {
    "start" => print("Starting...")
    "stop" => print("Stopping...")
    "restart" => print("Restarting...")
    _ => print("Unknown action")
  }

  // Match with number literals
  const statusCode = 200
  match(statusCode) {
    200 => print("OK")
    404 => print("Not Found")
    500 => print("Internal Server Error")
    _ => print("Unknown status")
  }

  // Match with variable assignment in body
  const grade = "A"
  const points = 0
  match(grade) {
    "A" => const a = 100
    "B" => const b = 85
    "C" => const c = 70
    "D" => const d = 55
    _ => const e = 0
  }

  // Match with function calls in body
  const level = "debug"
  match(level) {
    "debug" => print("Debug mode enabled")
    "info" => print("Info level logging")
    "warn" => print("Warning level")
    "error" => print("Error level")
  }

  // Match with array results
  const resultType = "array"
  match(resultType) {
    "array" => const data1 = [1, 2, 3]
    "object" => const data2 = {
      x: 1,
      y: 2
    }
    _ => const data3 = []
  }

  // Match with object results
  const format = "json"
  match(format) {
    "xml" => const output1 = {
      type: "xml",
      ext: ".xml"
    }
    "json" => const output2 = {
      type: "json",
      ext: ".json"
    }
    "csv" => const output3 = {
      type: "csv",
      ext: ".csv"
    }
    _ => const output4 = {
      type: "unknown",
      ext: ""
    }
  }
}