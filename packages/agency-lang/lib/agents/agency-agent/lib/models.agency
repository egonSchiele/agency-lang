/*
 * Model selection policy for the Agency Agent.
 *
 * Pure, side-effect-free helpers (no memory/LLM init on import) so they
 * can be unit-tested in isolation. `shared.agency` consumes these and
 * owns the actual side effects (setLlmOptions, slow-model state, exit).
 *
 * Two jobs:
 *   - `resolveDetected` — decide which provider's defaults to use,
 *     honoring an explicit `--provider` flag over env auto-detection.
 *   - `planModels` — given that provider, turn the four CLI flag values
 *     into the concrete fast/slow model + provider to apply.
 */
import { pickProvider, envVarFor } from "std::llm"
import { keys } from "std::object"
import { env } from "std::system"

import { slotKind, canonicalSlot } from "./slots.agency"

// Default models per provider. `slowProvider` pins the provider for the
// deep-reasoning call: OpenAI needs the Responses API for reasoning /
// extended thinking; native providers use their own. Used as fallbacks
// when the user doesn't pass --model / --fastmodel / --slowmodel.
//
// OpenRouter fronts many open models; its defaults are a reasoning model
// for the fast path and GLM for deep work (the model the custom-providers
// doc uses). `slowProvider` stays "openrouter" — no Responses-style API.
// (Keep these notes out of the object literal below: comments inside an
// object literal hit a parser bug.)
type ProviderModels = {
  fast: string;
  slow: string;
  slowProvider: string
}

export static const MODELS: Record<string, ProviderModels> = {
  openai: {
    fast: "gpt-4o-mini",
    slow: "gpt-5.5",
    slowProvider: "openai-responses"
  },
  anthropic: {
    fast: "claude-sonnet-4-6",
    slow: "claude-opus-4-8",
    slowProvider: "anthropic"
  },
  google: {
    fast: "gemini-3.5-flash",
    slow: "gemini-3.1-pro-preview",
    slowProvider: "google"
  },
  openrouter: {
    fast: "deepseek/deepseek-r1",
    slow: "z-ai/glm-5.2",
    slowProvider: "openrouter"
  }
}

// Hosted providers smoltalk reaches through a user-supplied base URL (a
// self-hosted proxy / generic OpenAI-compatible endpoint). We validate the
// base URL upfront — alongside the API key — so the agent fails loudly at
// startup instead of surfacing smoltalk's error on the first llm() call.
// These have no default models (the model names are deployment-specific), so
// they are NOT in MODELS and always require an explicit --model.
static const BASE_URL_PROVIDERS: Record<string, string> = {
  litellm: "LITELLM_BASE_URL"
}

/** Verify a provider's required env config is present. Checks the API-key
 *  var (via `envVarFor`) and, for proxy providers, the base-URL var. A
 *  truly-custom/local provider (no recognized key var, no base-URL
 *  requirement) passes through untouched, so `--provider llama-cpp --model
 *  x.gguf` still needs no hosted key. Returns the provider on success or a
 *  ready-to-print failure. */
def checkProviderEnv(provider: string): Result<string> {
  const varName = envVarFor(provider)
  if (varName != "" && (env(varName) == null || env(varName) == "")) {
    return failure("No API key for provider '${provider}'. Set ${varName}.")
  }
  const baseVar = BASE_URL_PROVIDERS[provider]
  if (baseVar != undefined && (env(baseVar) == null || env(baseVar) == "")) {
    return failure(
      "Provider '${provider}' needs a base URL. Set ${baseVar} (your proxy URL).",
    )
  }
  return success(provider)
}

// The agent always uses the OpenAI Responses API (not Chat Completions) for
// OpenAI, so provider-hosted web search is available on every OpenAI model.
// For any other provider the caller's resolved provider is used unchanged.
def agentProvider(detected: string, fallback: string): string {
  if (detected == "openai") {
    return "openai-responses"
  }
  return fallback
}

// The concrete models + providers to apply, produced by `planModels`.
// `fastProvider` is what `setLlmOptions` receives ("" lets smoltalk
// resolve the provider from the model name).
export type ModelPlan = {
  fastModel: string;
  fastProvider: string;
  slowModel: string;
  slowProvider: string
}

/** Decide which provider's default models to use, given the four
 *  (already-normalized-to-"") CLI flag values.
 *
 *  - An explicit `--provider` for a provider with defaults (a key in
 *    MODELS: openai/anthropic/google/openrouter) wins outright: we use
 *    its defaults and SKIP env auto-detection entirely. This is what lets
 *    `--provider openai` work even when a stale/invalid ANTHROPIC_API_KEY
 *    is set. We also verify the provider's key (and base URL, for a proxy)
 *    is present via `checkProviderEnv` so we fail loudly up front.
 *  - An explicit `--provider` for a provider WITHOUT defaults (a proxy
 *    like litellm, or a custom/local one) is only valid alongside an
 *    explicit model; otherwise it's an error. With a model it still goes
 *    through `checkProviderEnv`, so a recognized proxy's missing
 *    key/base-URL is caught here too.
 *  - With no `--provider`, fall back to env auto-detection
 *    (`pickProvider`, with openrouter as a last resort) whenever defaults
 *    are actually needed.
 *
 *  Returns the provider name whose MODELS bucket should supply defaults,
 *  or a failure whose message is ready to print. */
export def resolveDetected(
  model: string,
  fast: string,
  slow: string,
  provider: string,
): Result<string> {
  const needFast = fast == "" && model == ""
  const needSlow = slow == "" && model == ""

  if (provider != "") {
    // A provider with no built-in defaults (a custom/local one, or a proxy
    // like litellm whose model names are deployment-specific) can't supply
    // fast/slow models, so it's only usable alongside an explicit model.
    if (MODELS[provider] == undefined && (needFast || needSlow)) {
      const known = Object.keys(MODELS)
      return failure(
        "--provider ${provider} has no built-in defaults; also pass --model (or --fastmodel/--slowmodel). Providers with defaults: ${known.join(", ")}.",
      )
    }
    // Recognized provider (a forced one with defaults, or a proxy with an
    // explicit model): fail loudly now if its key / base URL is missing
    // rather than emitting a confusing auth error on the first llm() call.
    return checkProviderEnv(provider)
  }

  if (needFast || needSlow) {
    // Env auto-detection. openrouter is last so an explicit big-three key
    // still wins; it's only picked when it's the only key present.
    return pickProvider(["anthropic", "google", "openai", "openrouter"])
  }
  // Everything came from --model; the defaults bucket is never read.
  return success("openai")
}

/** Turn the four CLI flag values plus the resolved `detected` provider
 *  into the concrete models/providers to apply. Pure. Precedence:
 *  --fastmodel/--slowmodel win over --model, which wins over the
 *  `detected` provider's defaults.
 *
 *  The `detected` bucket (MODELS[detected]) is only read when a default
 *  is actually needed — i.e. when the corresponding model flag is
 *  absent. For a custom/local provider (no bucket) `resolveDetected`
 *  guarantees an explicit model was supplied, so the defaults are never
 *  dereferenced. */
export def planModels(
  model: string,
  fast: string,
  slow: string,
  provider: string,
  detected: string,
): ModelPlan {
  let fastModel = fast
  if (fastModel == "") {
    if (model != "") {
      fastModel = model
    } else {
      fastModel = MODELS[detected].fast
    }
  }

  let slowModel = ""
  let slowProvider = ""
  if (slow != "") {
    slowModel = slow
    slowProvider = provider
  } else if (model != "") {
    slowModel = model
    slowProvider = provider
  } else {
    slowModel = MODELS[detected].slow
    slowProvider = MODELS[detected].slowProvider
  }

  // The fast wrap is the one that matters in the common case: when env
  // auto-detection picks OpenAI, `provider` is "" and agentProvider promotes
  // it to "openai-responses". The slow wrap is a no-op on the default branch
  // (MODELS.openai.slowProvider is already "openai-responses") but is needed
  // when --slow / --model passes an OpenAI model with a non-responses
  // `provider` flag — the local `slowProvider` here is the locally-computed
  // value above, not the function parameter.
  return {
    fastModel: fastModel,
    fastProvider: agentProvider(detected, provider),
    slowModel: slowModel,
    slowProvider: agentProvider(detected, slowProvider)
  }
}

// Field order { model, provider } is locked by JSON snapshot tests; do not reorder.
export type ModelSpec = {
  model: string;
  provider: string
}

/** Parse a possibly-unified model spec. When a provider is already established
  (explicit --provider/settings), never split: the whole string is the model id
  (OpenRouter ids contain "/"). Else split on the FIRST "/" only when the prefix
  is a recognized provider; otherwise the whole string is the model. */
export def parseModelSpec(
  spec: string,
  providerEstablished: boolean,
  knownProviders: string[],
): ModelSpec {
  if (providerEstablished) {
    return {
      model: spec,
      provider: ""
    }
  }
  const idx = spec.indexOf("/")
  if (idx <= 0) {
    return {
      model: spec,
      provider: ""
    }
  }
  const prefix = spec.substring(0, idx)
  if (knownProviders.includes(prefix)) {
    return {
      model: spec.substring(idx + 1),
      provider: prefix
    }
  }
  return {
    model: spec,
    provider: ""
  }
}

// Field order { model, provider, via } is locked by JSON snapshot tests.
export type Resolved = {
  model: string;
  provider: string;
  via: string
}

/** Built-in default for (provider, slot, price). Phase 1 honors only "standard",
  deriving fast/slow from `planModels` along the DETECTED-provider path (provider
  arg empty, detected = provider) so the values are byte-identical to today's env
  auto-detection. `derived` slots (embedding) return empty; memory derives the
  embed model from the active provider. Providers without baked defaults return
  failure. Dispatch on SLOT_KIND so the mapping lives in one table. */
export def priceDefault(
  provider: string,
  slot: string,
  price: string,
): Result<Resolved> {
  if (MODELS[provider] == null) {
    return failure(
      "Provider '${provider}' has no built-in defaults; pass an explicit model.",
    )
  }
  const plan = planModels("", "", "", "", provider)
  const kind = slotKind(slot)
  if (kind == "fast") {
    return success(
      {
      model: plan.fastModel,
      provider: plan.fastProvider,
      via: "built-in:price=${price}"
    },
    )
  }
  if (kind == "slow") {
    return success(
      {
      model: plan.slowModel,
      provider: plan.slowProvider,
      via: "built-in:price=${price}"
    },
    )
  }
  if (kind == "derived") {
    return success(
      {
      model: "",
      provider: "",
      via: "built-in:embedding(derived)"
    },
    )
  }
  return failure("Unknown slot '${slot}'.")
}

/** Providers Agency can actually configure: those with baked defaults plus the
  base-URL proxy providers. Source-of-truth derived (MODELS + BASE_URL_PROVIDERS),
  not a hand-maintained list, so it never drifts. Used by parseModelSpec. */
export def knownProviders(): string[] {
  return Object.keys(MODELS).concat(Object.keys(BASE_URL_PROVIDERS))
}

/** Split a --model value: `slot=model` becomes per-slot (alias-resolved); a bare
  `model` becomes a global pin ({slot:""}). The "=" must precede any "/" so a
  unified provider/model value (anthropic/claude) is NOT misread as a slot key.
  Returns {slot, model} (distinct shape from parseModelSpec's {model, provider}). */
export def parseModelFlag(value: string): { slot: string; model: string } {
  const eq = value.indexOf("=")
  const slash = value.indexOf("/")
  if (eq > 0 && (slash == -1 || eq < slash)) {
    return {
      slot: canonicalSlot(value.substring(0, eq)),
      model: value.substring(eq + 1)
    }
  }
  return {
    slot: "",
    model: value
  }
}

