// `if <cond> then <a> else <b>` — a conditional expression (Agency's readable
// alternative to a ternary). Compiles to a TS conditional, so it works anywhere
// an expression can: assignment RHS, object values, function arguments, return.

def label(n: number): string {
  return if n > 100 then "big" else "small"
}

node basic(age: number): string {
  const kind = if age > 18 then "adult" else "child"
  return kind
}

// As an object property value.
node objectValue(age: number): string {
  const person = { kind: if age > 18 then "adult" else "child", age: age }
  return "${person.kind}/${person.age}"
}

// As a function argument, and a non-literal (call) branch.
node arg(n: number): string {
  return label(if n > 0 then n else 0)
}

// Number-typed branches.
node numeric(flag: boolean): number {
  const points = if flag then 100 else 0
  return points + 1
}
