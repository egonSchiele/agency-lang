const log = []

def greet() {
  log.push("greet-before")
  const name = interrupt({
    type: "safe",
    message: "Who do you want to say bye to?"
  })
  log.push("greet-after-${name}")
  return "greet result"
}

def readStuff() {
  log.push("read-before")
  return interrupt({
    type: "read",
    message: "Can I read a file?"
  })
  log.push("read-after")
  return "read result"
}

def foo() {
  const res1 = greet()
  const res2 = readStuff()
  log.push(res1)
  log.push(res2)
  log.push("foo-done")
  return "foo result"
}

node main() {
  handle {
    const res1 = foo()
    log.push("foo returned ${res1}")
  } with (data) {
    if (data.type == "safe") {
      return approve("Alice")
    } else if (data.type == "read") {
      return reject("not allowed")
    }
  }
  return log
}

node bothRejected() {
  handle {
    const res1 = foo()
    log.push("foo returned ${res1}")
  } with (data) {
    if (data.type == "safe") {
      return reject()
    } else if (data.type == "read") {
      return reject("not allowed")
    }
  }
  return log
}