import { unwrapGuard } from "std::agents/shared"
import { GuardFailureData } from "std::thread"

node returnsValueOnSuccess(): boolean {
  const r: Result<string, GuardFailureData> = success("ok")
  return unwrapGuard(r, "X") == "ok"
}

node returnsTripMessageOnFailure(): boolean {
  const r: Result<string, GuardFailureData> = failure({ type: "timeoutFailure" })
  return unwrapGuard(r, "Planner") =~ re/Planner stopped/
}
