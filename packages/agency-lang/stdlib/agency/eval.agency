import { run, CompiledProgram } from "std::agency"
import {
  _initializeEvalRun,
  _prepareEvalRunTask,
  _completeEvalRunTask,
  _recordEvalRunTaskError,
  _formatEvalRunFailure,
  _finishEvalRun,
 } from "agency-lang/stdlib-lib/agencyEval.js"

export type EvalRunTask = {
  task_id: string;
  rubric: string;
  args: Record<string, any>;
  node?: string;
  working_dir?: string
}

export type EvalRunTaskResult = {
  taskId: string;
  status: "success" | "error";
  evalRecordPath: string;
  statelogPath: string;
  workdirPath: string;
  errorMessage?: string
}

export type EvalRunResult = {
  runId: string;
  runDir: string;
  agent: string;
  tasks: EvalRunTaskResult[];
  okCount: number;
  errorCount: number
}

export def evalRun(
  compiled: CompiledProgram,
  tasks: EvalRunTask[],
  node: string = "main",
  runsDir: string = "runs/",
  runId: string = "",
  continueOnError: boolean = true,
): EvalRunResult {
  """
  Run a compiled Agency program against eval tasks, writing per-task statelog and eval artifacts under runsDir/runId. Subprocess execution goes through std::agency.run so caller handlers still approve subprocess execution and child interrupts.

  @param compiled - Compiled program from std::agency.compile
  @param tasks - Eval tasks to run sequentially
  @param node - Default node to invoke when a task does not specify one
  @param runsDir - Output directory for eval runs
  @param runId - Optional run id; generated when empty
  @param continueOnError - Continue remaining tasks after a task error
  """
  const runState = _initializeEvalRun(compiled, tasks, node, runsDir, runId, continueOnError)
  for (task in runState.tasks) {
    const preparedResult = try _prepareEvalRunTask(runState, task)
    if (isFailure(preparedResult)) {
      _recordEvalRunTaskError(runState, task, _formatEvalRunFailure(preparedResult))
      if (!continueOnError) {
        return _finishEvalRun(runState)
      }
      continue
    }
    const prepared = preparedResult.value
    const taskNode = task.node ?? node
    const runResult = run(
      compiled: compiled,
      node: taskNode,
      args: task.args,
      logFile: prepared.statelogPath,
      cwd: prepared.workdirPath,
    )
    let errorMessage = ""
    if (isFailure(runResult)) {
      errorMessage = _formatEvalRunFailure(runResult)
    }
    const completedResult = try _completeEvalRunTask(runState, prepared, errorMessage)
    if (isFailure(completedResult)) {
      _recordEvalRunTaskError(runState, prepared, _formatEvalRunFailure(completedResult))
      if (!continueOnError) {
        return _finishEvalRun(runState)
      }
    } else {
      const taskResult = completedResult.value
      if (taskResult.status == "error" && !continueOnError) {
        return _finishEvalRun(runState)
      }
    }
  }
  return _finishEvalRun(runState)
}
