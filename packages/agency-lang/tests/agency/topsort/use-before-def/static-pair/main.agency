// Two same-file statics where `dependent` is declared BEFORE `base`,
// but `dependent`'s initializer references `base`. Pre-Task-4 this
// silently compiled (topsort would reorder them); post-Task-4 the
// compiler emits a use-before-def error naming both source lines.
static const dependent = base + "!"
static const base = "hello"

node main() {
  return dependent
}
