class Math {
  factor: number

  multiply(x: number): Result {
    return success(x * this.factor)
  }

  divide(x: number, divisor: number): Result {
    if (divisor == 0) {
      return failure("division by zero")
    }
    return success(x / divisor)
  }
}

def divideBy(x: number, divisor: number): Result {
  if (divisor == 0) {
    return failure("division by zero")
  }
  return success(x / divisor)
}

node main() {
  let math = new Math(2)

  // pipe into method without placeholder
  let r1 = success(5) |> math.multiply

  // pipe into function with partial application
  let r2 = success(10) |> divideBy.partial(divisor: 2)

  // chaining multiple method calls
  let r3 = success(3) |> math.multiply |> math.multiply

  // short-circuit on failure
  let r4 = success(10) |> divideBy.partial(divisor: 0) |> math.multiply

  return {
    r1: r1.value,
    r2: r2.value,
    r3: r3.value,
    r4Failed: isFailure(r4),
    r4Error: r4.error
  }
}
