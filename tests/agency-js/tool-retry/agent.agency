import { safe lookupItem, saveItem, flakyWrite, resetCounters } from "./tools.js"

// --- Helper functions ---

// lookupTool wraps the safe imported function lookupItem.
// Since lookupItem is marked safe, calling it does not set __retryable = false,
// so lookupTool remains retryable when used as a tool.
def lookupTool(id: string) {
  return lookupItem(id)
}

// saveAndLookupTool calls saveItem (not marked safe), so __retryable is set
// to false. If this tool throws after calling saveItem, it cannot be retried.
def saveAndLookupTool(id: string) {
  saveItem(id)
  const item = lookupItem(id)
  return item
}

// safeLookupHelper is an agency-defined function explicitly marked safe.
// The safe keyword is an assertion by the developer that this function is
// always safe to retry, regardless of what it calls internally.
safe def safeLookupHelper(id: string) {
  return lookupItem(id)
}

// safeWrapperTool calls safeLookupHelper, which is marked safe def.
// Since safeLookupHelper is safe, this tool remains retryable — the LLM
// can retry it if it throws an error.
def safeWrapperTool(id: string) {
  return safeLookupHelper(id)
}

// derivedSafeWrapperTool calls lookupTool, which is NOT marked safe def.
// However, lookupTool only calls safe imported functions internally, so
// its safety is derived at runtime: no unsafe functions are ever called
// in the chain, so the tool remains retryable.
def derivedSafeWrapperTool(id: string) {
  return lookupTool(id)
}

// unsafeChainTool calls saveItem (unsafe), then calls lookupTool which
// throws. Even though lookupTool itself is safe, saveItem is NOT. So if
// lookupTool throws after saveItem is called, this call should NOT
// be retried.
def unsafeChainTool(id: string) {
  saveItem(id)
  return lookupTool(id)
}

def resetCountersTool() {
  return resetCounters()
}

// --- Class with safe and non-safe methods ---

class ItemService {
  prefix: string

  safe safeLookup(id: string): any {
    return lookupItem("${this.prefix}-${id}")
  }

  unsafeSaveAndLookup(id: string): any {
    saveItem(id)
    return lookupItem("${this.prefix}-${id}")
  }
}

// Tool wrappers for class methods
def safeMethodTool(id: string) {
  let svc = new ItemService("svc")
  return svc.safeLookup(id)
}

def unsafeMethodTool(id: string) {
  let svc = new ItemService("svc")
  return svc.unsafeSaveAndLookup(id)
}

// --- Nested impure calls inside safe functions/methods ---

// A safe def function with an impure call (flakyWrite, not marked safe)
// inside an if block. Without the fix, the nested block would emit
// __retryable = false because flakyWrite is impure, making the tool
// non-retryable despite the safe keyword. With the fix, the safe flag
// propagates into nested blocks, so the tool stays retryable.
safe def safeNestedWrite(id: string) {
  if (id != "") {
    return flakyWrite(id)
  }
  return id
}

def safeNestedTool(id: string) {
  return safeNestedWrite(id)
}

// A class with a safe method that has an impure call (flakyWrite)
// inside an if block. Same scenario as above but for class methods.
class NestedService {
  prefix: string

  safe nestedWrite(id: string): any {
    if (id != "") {
      return flakyWrite("${this.prefix}-${id}")
    }
    return id
  }
}

def safeNestedMethodTool(id: string) {
  let svc = new NestedService("nsvc")
  return svc.nestedWrite(id)
}

// --- Nested impure calls inside for/while loops ---

// A safe def function with an impure call inside a for loop.
safe def safeForLoopWrite(ids: string[]) {
  let result = ""
  for (id in ids) {
    result = flakyWrite(id)
  }
  return result
}

def safeForLoopTool(id: string) {
  return safeForLoopWrite([id])
}

// A safe def function with an impure call inside a while loop.
safe def safeWhileLoopWrite(id: string) {
  let done = false
  while (!done) {
    let result = flakyWrite(id)
    done = true
    return result
  }
  return id
}

def safeWhileLoopTool(id: string) {
  return safeWhileLoopWrite(id)
}

// --- Test nodes ---

// Test 1: A tool that directly calls a safe imported function.
// The tool is retryable, so the LLM can retry on error.
node testSafeRetry() {
  resetCountersTool()
  uses lookupTool
  const result = llm("Look up item with id 'abc'. Use the lookupTool. If you get a temporary error, retry the same tool call.")
  return result
}

// Test 2: A tool that calls an unsafe imported function (saveItem).
// The tool is not retryable, so it is removed on error.
node testUnsafeNoRetry() {
  resetCountersTool()
  uses saveAndLookupTool
  const result = llm("Save and look up item 'xyz'. Use the saveAndLookupTool.")
  return result
}

// Test 3: A tool that calls a safe def agency function (safeLookupHelper).
// Because safeLookupHelper is marked safe, this tool remains retryable.
// The LLM should retry on error and succeed on the second attempt.
node testSafeDefRetry() {
  resetCountersTool()
  uses safeWrapperTool
  const result = llm("Look up item with id 'def'. Use the safeWrapperTool. If you get a temporary error, retry the same tool call.")
  return result
}

// Test 4: A tool that calls an unmarked agency function (lookupTool) which
// only calls safe imported functions. Safety is derived at runtime — since
// no unsafe function is ever called, the tool stays retryable.
node testDerivedSafeRetry() {
  resetCountersTool()
  uses derivedSafeWrapperTool
  const result = llm("Look up item with id 'ghi'. Use the derivedSafeWrapperTool. If you get a temporary error, retry the same tool call.")
  return result
}

// Test 5: A tool that calls saveItem (unsafe), then calls lookupTool which
// throws. The outer function's __retryable is false (due to saveItem), and
// the catch block ANDs it with the inner ToolCallError's retryable, making
// the whole tool non-retryable.
node testUnsafeChainNoRetry() {
  resetCountersTool()
  uses unsafeChainTool
  const result = llm("Save and look up item 'jkl'. Use the unsafeChainTool.")
  return result
}

// Test 6: A tool that calls a safe class method.
// The method is marked safe, so the tool remains retryable.
node testSafeMethodRetry() {
  resetCountersTool()
  uses safeMethodTool
  const result = llm("Look up item with id 'mno'. Use the safeMethodTool. If you get a temporary error, retry the same tool call.")
  return result
}

// Test 7: A tool that calls a non-safe class method (calls saveItem internally).
// The method is not marked safe, so the tool is not retryable.
node testUnsafeMethodNoRetry() {
  resetCountersTool()
  uses unsafeMethodTool
  const result = llm("Save and look up item 'pqr'. Use the unsafeMethodTool.")
  return result
}

// Test 8: A safe def function with an impure call inside a nested if block.
// The safe flag should propagate into nested blocks, keeping the tool retryable.
node testSafeNestedRetry() {
  resetCountersTool()
  uses safeNestedTool
  const result = llm("Look up item with id 'stu'. Use the safeNestedTool. If you get a temporary error, retry the same tool call.")
  return result
}

// Test 9: A safe class method with an impure call inside a nested if block.
// The safe flag should propagate into nested blocks, keeping the tool retryable.
node testSafeNestedMethodRetry() {
  resetCountersTool()
  uses safeNestedMethodTool
  const result = llm("Look up item with id 'vwx'. Use the safeNestedMethodTool. If you get a temporary error, retry the same tool call.")
  return result
}

// Test 10: A safe def function with an impure call inside a for loop.
// The safe flag propagates into loop bodies.
node testSafeForLoopRetry() {
  resetCountersTool()
  uses safeForLoopTool
  const result = llm("Look up item with id 'for1'. Use the safeForLoopTool. If you get a temporary error, retry the same tool call.")
  return result
}

// Test 11: A safe def function with an impure call inside a while loop.
// The safe flag propagates into loop bodies.
node testSafeWhileLoopRetry() {
  resetCountersTool()
  uses safeWhileLoopTool
  const result = llm("Look up item with id 'whl1'. Use the safeWhileLoopTool. If you get a temporary error, retry the same tool call.")
  return result
}