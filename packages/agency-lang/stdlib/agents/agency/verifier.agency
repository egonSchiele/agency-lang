/** @module
  @summary Runs an Agency program and judges its actual result against a task.

  The verifier runs; review reads. To check source text without executing it,
  use agencyReviewAgent instead.
*/
import { runCode } from "std::agency"
import { Feedback } from "std::agents/lib/feedback"
import { llmOptions } from "std::agents/lib/shared"
import { systemMessage, threadIsNew } from "std::thread"

static const systemPrompt = """You judge whether a program's actual result satisfies a task. For each finding, return a Feedback item: error=true when it fails the task (name the specific problem), error=false for a satisfied point."""

def judgeResult(
  task: string,
  data: any,
  model: string,
  provider: string,
): Feedback[] {
  if (threadIsNew()) {
    systemMessage(systemPrompt)
  }
  const items: Feedback[] = llm("Task:\n${task}\n\nThe program ran and produced this result:\n${data}", llmOptions(model, provider))
  return items
}

def runAndJudge(
  source: string,
  task: string,
  model: string,
  provider: string,
  session: string,
): Result<Feedback[]> {
  const ran = runCode(source)
  if (ran is failure(err)) {
    return success([{ error: true, feedback: "The program failed to run: ${err}" }])
  }
  let items: Feedback[] = []
  thread(label: "agencyVerifierAgent", session: session) {
    items = judgeResult(task, ran.value, model, provider)
  }
  return success(items)
}

export def agencyVerifierAgent(
  source: string,
  task: string,
  context: string = "",
  maxCost: number = $20.00,
  maxTime: number = 15m,
  model: string = "",
  provider: string = "",
  session: string = "",
): Result<Feedback[]> {
  """
  Run an Agency program and judge its result against the task. A program that
  fails to run yields a single error finding rather than a failure, so callers
  can always read findings.

  @param source - The Agency program to run
  @param task - What the program's result must satisfy
  @param context - Extra material for the judgment, or ""
  @param maxCost - Hard spend cap
  @param maxTime - Hard wall-clock cap
  @param model - Model override, or "" for the ambient model
  @param provider - Provider for the model override
  @param session - Session name to share a thread across calls, or "" for isolated
  """
  const captured = guard(cost: maxCost, time: maxTime) {
    return runAndJudge(source, task, model, provider, session)
  }
  // isFailure, not match: agents can run inside a supervise block, and a
  // match expression inside a block that pauses and resumes evaluates to
  // null. See tests/agency/supervise/nestedGuardResume.agency.
  if (isFailure(captured)) {
    // Callers can always read findings: a verifier that was cut short
    // reports that as an advisory item, not a blocking failure.
    return success([{ error: false, feedback: "Verification stopped early: ${captured.error.type} cap reached." }])
  }
  return captured.value
}
