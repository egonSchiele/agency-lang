def nextTwo(): number[] {
  const subMsgs = subthread {
    const foo: number[] = llm("What are the next 2 prime numbers after that?")
  }
  return {
    foo: foo,
    subMsgs: subMsgs
  }
}

node main() {
  const msgs = thread {
    const res1: number[] = llm("What are the first 5 prime numbers?")
    const res2 = nextTwo()
    const res3 = nextTwo()
  }
  return {
    res1: res1,
    res2: res2,
    res3: res3,
    msgs: msgs
  }
}