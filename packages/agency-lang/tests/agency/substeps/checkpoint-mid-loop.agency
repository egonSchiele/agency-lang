import { getMutable, setMutable } from "../../helpers/mutableVar.js"

node main() {
  for (i in range(4)) {
    setMutable("log", getMutable("log", "") + i)
    if (i == 2) {
      const cp = checkpoint()
    }
    if (i == 3) {
      if (getMutable("restoreCount", 0) < 1) {
        setMutable("restoreCount", getMutable("restoreCount", 0) + 1)
        restore(cp, {})
      }
    }
  }
  return getMutable("log", "")
}
