node main() {
  let arr = [1, 2, 3, 4, 5]
  let bothBounds = arr[1:3]
  let startOnly = arr[2:]
  let endOnly = arr[:3]
  let noBounds = arr[:]
  let negativeStart = arr[-2:]
  let negativeEnd = arr[:-1]
  let chained = arr[1:4][0:2]
  let n = 3
  let variableBound = arr[0:n]
  let str = "hello"
  let stringSlice = str[1:3]
  let stringNegative = str[-3:]
  return {
    bothBounds: bothBounds,
    startOnly: startOnly,
    endOnly: endOnly,
    noBounds: noBounds,
    negativeStart: negativeStart,
    negativeEnd: negativeEnd,
    chained: chained,
    variableBound: variableBound,
    stringSlice: stringSlice,
    stringNegative: stringNegative
  }
}
