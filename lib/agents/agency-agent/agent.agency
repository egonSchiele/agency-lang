import tool { addTask, listTasks, markTaskDone } from "./subagents/task.agency"
import tool { writeToPlan, readPlan } from "./subagents/plan.agency"
import tool { writeCode, appendCode, readCode } from "./subagents/code.agency"
import { syntaxHighlight } from "../../utils/agentUtils.js"
// todo allow this
// import { Plan } from "./subagents/plan.agency"

systemPrompt = read("./prompts/system.md")
planPrompt = read("./prompts/plan.md")

type Mode = "create" | "modify"
type NextAction = { type: "askUser"; question: string } | { type: "done" } | { type: "start" }

strategy = { 
  type: "race",
  params: { 
    strategies: [
      { 
      type: "fallback",
      params: { 
        strategies: ["gemini-2.5-flash", "gemini-2.5-pro"],
        config: { 
          fallbackOn: ["error"]
        }
      }
    },
      { 
      type: "fallback",
      params: { 
        strategies: ["gemini-2.5-flash-lite", "gemini-2.5-pro"],
        config: { 
          fallbackOn: ["error"]
        }
      }
    }
    ]
  }
}

config = { 
  strategy: strategy,
  responseFormatOptions: { 
    strict: true,
    numRetries: 2,
    allowExtraKeys: true
  }
}
/* config = {
model: {
optimizeFor: ["reasoning", "speed", "cost"],
providers: ["openai", "google"],
limit: {
cost: 40
}
},
responseFormatOptions: {
strict: true
}
} */

def printCode(code: string): string {
  """
  Use this tool to print code to the terminal with syntax highlighting.
  Use this to print any generated code you want the user to look at.
  """
  print(syntaxHighlight(code, "ts"))
  return "printed code successfully"
}

def writeCodeWithConfirm(filename: string, content: string): string {
  """
  Use this tool to write code to a file to the filesystem. The filename should include the path and extension (e.g., 'lib/agents/myAgent.agency').
  """
  print(color.yellow())
  message = "\nYou're about to write to the file ${filename} with the following content\n\n"
  return interrupt({ 
    tool: "writeCodeWithConfirm",
    message: message,
    content: content
  })
  write(filename, content)
}

node main() {
  print(color.cyan("Welcome to the Agency Agent!"))
  print(color.cyan("Would you like to create a new agent or modify an existing one?"))
  userinput = input("(create/modify) ")
  thread {
    mode: Mode = llm("categorize this user response as 'create' or 'modify': ${userinput}", config)
  }
  print(color.cyan("Great! Let's ${mode} an agent."))
  match(mode) {
    "create" => return plan("create", "", null)
    "modify" => return readExisting()
  }
}

node readExisting() {
  filepath = input("Enter the path to the .agency file you want to modify: ")
  existingCode = read(filepath)
  print(color.cyan("Here's the existing code:"))
  printCode(existingCode)
  return plan("modify", existingCode, filepath)
}

node printSample() {
  codeSample = read("./prompts/codeSample.agency")
  print(color.cyan("Here's a sample of how you might structure your code in the agency language:"))
  printCode(codeSample)
}

node plan(mode, existingCode, existingFilename: string | null) {
  print(color.cyan("Let's start by coming up with a plan for what you want to accomplish."))
  modeContext = ""
  if (mode == "modify") {
    modeContext = """
    You are in MODIFY mode. The user has an existing agent they want to modify. Here is the existing code:
    
    ```
    ${existingCode}
    ```
    
    Focus on understanding what changes the user wants to make to this existing agent.
    """
  }
  thread {
    system("${systemPrompt}\n\n${planPrompt}${modeContext}")
    userMsg = input("What would you like to accomplish today? ")
    nextAction: NextAction = { 
      type: "start"
    }
    while (nextAction.type != "done") {
      uses writeToPlan, readPlan, print
      nextAction: NextAction = llm("${userMsg}", config)
      if (nextAction.type == "askUser") {
        userMsg = input("${nextAction.question} ")
      }
    }

    plan = readPlan()
    print(color.cyan("Here's the plan we've come up with"))
    printJSON(plan)
  }
  return design(plan, mode, existingCode, existingFilename)
}

type Plan = {
  overallGoal: string;
  desiredActions: string[] # array of descriptions of each action
}

type DesignAction = { type: "askUser"; question: string } | { type: "done"; finalCode: string; filename: string } | { type: "start" }

node design(plan, mode, existingCode, existingFilename: string | null) {
  designPrompt = read("./prompts/design.md")
  prompt = ""
  if (mode == "modify") {
    print(color.cyan("Now let's modify the existing agent based on the plan."))
    prompt = """
    You are in MODIFY mode. Here is the existing agent code:
    
    ```
    ${existingCode}
    ```
    
    The user wants to make the following modifications:
    Goal: ${plan.overallGoal}
    Desired changes: ${plan.desiredActions}
    
    Modify the existing code to accomplish these changes. Preserve the existing style and structure where possible.
    """
  } else {
    print(color.cyan("Now let's design an agent to accomplish that plan."))
    prompt = """
    Help the user design an agent that can accomplish the following goal: ${plan.overallGoal}
    with the following actions: ${plan.desiredActions}.
    """
  }
  thread {
    system(designPrompt)
    userMsg = prompt
    nextAction: DesignAction = { 
      type: "start"
    }
    i = 0
    while (nextAction.type != "done") {
      i += 1
      print(color.blue("Design iteration ${i}"))
      nextAction: DesignAction = llm("${userMsg}", config)
      if (nextAction.type == "askUser") {
        userMsg = input("\n${nextAction.question} ")
      }
    }
  }
  print(color.green("Great! We've designed the agent. Now let's write the code for it."))
  printJSON(color.magenta(nextAction))
  nextAction.filename = nextAction.filename || "agent.agency"
  writeCodeWithConfirm(existingFilename || nextAction.filename, nextAction.finalCode)
}