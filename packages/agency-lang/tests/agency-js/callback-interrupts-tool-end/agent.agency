let count: number = 0
let toolExecutions: number = 0
let resumedResult: string = "MISSING"

def greet(): string {
  toolExecutions = toolExecutions + 1
  return "hi"
}

callback("onToolCallEnd") as data {
  if (data.toolName == "greet") {
    count = count + 1
    if (count == 1) {
      interrupt myapp::pause("toolEnd", { count: count })
    }
    // Second fire (after resume): the invoke step was skipped (already
    // marked complete) so the local `toolResult` is undefined unless
    // it's restored from the per-branch result. Capture it so the test
    // can assert the end-hook receives the actual tool output.
    if (count == 2) {
      resumedResult = data.result
    }
  }
}

node main() {
  const response = llm("call greet", { tools: [greet] })
  return [response, count, toolExecutions, resumedResult]
}
