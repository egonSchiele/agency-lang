// Omit<T, K>: the omitted key is gone from the schema; remaining keys are
// still required.
type User = {
  name: string,
  age: number,
  email: string,
}

node accepts() {
  const s = schema(Omit<User, "email">)
  const r = s.parseJSON("{\"name\": \"a\", \"age\": 1}")
  if (isSuccess(r)) {
    return r.value
  }
  return "parse failed"
}

node rejects() {
  const s = schema(Omit<User, "email">)
  const r = s.parseJSON("{\"name\": \"a\"}")
  if (isFailure(r)) {
    return "rejected"
  }
  return "accepted"
}
