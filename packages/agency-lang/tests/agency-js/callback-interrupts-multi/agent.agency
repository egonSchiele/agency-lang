let firedA: number = 0
let firedB: number = 0

callback("onLLMCallEnd") as data {
  firedA = firedA + 1
  if (firedA == 1) {
    interrupt myapp::pauseA("from A", { count: firedA })
  }
}

callback("onLLMCallEnd") as data {
  firedB = firedB + 1
  if (firedB == 1) {
    interrupt myapp::pauseB("from B", { count: firedB })
  }
}

node main() {
  const response = llm("say hi")
  return [response, firedA, firedB]
}
