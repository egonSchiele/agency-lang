}
},
responseFormatOptions: {
strict: true
}
} */

def printCode(code: string): string {
  """
  Use this tool to print code to the terminal with syntax highlighting.
  Use this to print any generated code you want the user to look at.
  """
  print(syntaxHighlight(code, "ts"))
  return "printed code successfully"
}

def writeCodeWithConfirm(filename: string, content: string): string {
  """
  Use this tool to write code to a file to the filesystem. The filename should include the path and extension (e.g., 'lib/agents/myAgent.agency').
  """
  print(color.yellow())
  message = "You're about to write to the file ${filename} with the following content"
  return interrupt({ 
    tool: "writeCodeWithConfirm",
    message: message,
    content: content
  })
  write(filename, content)
}

node main() {
  // return plan()
  //return printSample()
  plan = { 
    overallGoal: "Help with meal planning by generating meal plans with recipe imports and database interactions.",
    desiredActions: ["Scrape recipe data from a provided URL.", "Create ingredients in the database based on scraped data.", "Create meals in the database based on scraped recipe data."]
  }
  return design(plan)
}

node printSample() {
  codeSample = read("./prompts/codeSample.agency")
  print(color.cyan("Here's a sample of how you might structure your code in the agency language:"))
  printCode(codeSample)
}

node plan() {
  print(color.cyan("Let's start by coming up with a plan for what you want to accomplish."))
  thread {
    system("${systemPrompt}\n\n${planPrompt}")
    userMsg = input("What would you like to accomplish today? ")
    nextAction: NextAction = { 
      type: "start"
    }
    while (nextAction.type != "done") {
      uses writeToPlan, readPlan, print
      nextAction: NextAction = llm("${userMsg}", config)
      if (nextAction.type == "askUser") {
        userMsg = input("${nextAction.question} ")
      }
    }

    plan = readPlan()
    print(color.cyan("Here's the plan we've come up with"))
    printJSON(plan)
  }
  return design(plan)
}

type Plan = {
  overallGoal: string;
  desiredActions: string[] # array of descriptions of each action
}

type DesignAction = { type: "askUser"; question: string } | { type: "done"; finalCode: string; filename: string } | { type: "start" }

node design(plan) {
  print(color.cyan("Now let's design an agent to accomplish that plan."))
  designPrompt = read("./prompts/design.md")
  prompt = """
  Help the user design an agent that can accomplish the following goal: ${plan.overallGoal}
  with the following actions: ${plan.desiredActions}.
  """
  thread {
    system(designPrompt)
    userMsg = prompt
    nextAction: DesignAction = { 
      type: "start"
    }
    i = 0
    while (nextAction.type != "done") {
      i += 1
      print(color.blue("Design iteration ${i}"))
      uses print, printCode
      nextAction: DesignAction = llm("${userMsg}", config)
      if (nextAction.type == "askUser") {
        userMsg = input("\n${nextAction.question} ")
      }
    }
  }
  print(color.green("Great! We've designed the agent. Now let's write the code for it."))
  printJSON(color.magenta(nextAction))
  nextAction.filename = nextAction.filename || "agent.agency"
  writeCodeWithConfirm(nextAction.filename, nextAction.finalCode)
}