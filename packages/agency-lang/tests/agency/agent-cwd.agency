import { getAgentCwd, setAgentCwd, applyAgentCwd } from "std::index"

node defaultsToEmpty(): boolean {
  return getAgentCwd() == ""
}

node setThenGet(): boolean {
  setAgentCwd("/abs/dir")
  return getAgentCwd() == "/abs/dir"
}

node applyJoinsRelative(): boolean {
  setAgentCwd("/abs/dir")
  return applyAgentCwd("foo") == "/abs/dir/foo"
}

node applyKeepsAbsolute(): boolean {
  setAgentCwd("/abs/dir")
  return applyAgentCwd("/other") == "/other"
}

node applyEmptyReturnsBase(): boolean {
  setAgentCwd("/abs/dir")
  return applyAgentCwd("") == "/abs/dir"
}

node applyUnsetPassesThrough(): boolean {
  return applyAgentCwd("foo") == "foo"
}

import { bash, exists } from "std::shell"
import { edit, remove } from "std::fs"
import { cwd } from "std::system"
import { join } from "std::path"

// Gap 5 — with NO agent cwd set, a relative read resolves against the
// process working directory (the package root when the test runner
// invokes this), reading "from module" via the cwd-relative path.
node unsetReadsCwd(): boolean {
  const r = read("tests/agency/cwd-probe.txt") with approve
  if (r is success(v)) {
    return v.trim() == "from module"
  }
  return false
}

// Two same-named files in different dirs prove the read SWITCHES based on
// the agent cwd when the caller opts in. With cwd = fixture-a and
// useAgentCwd: true, the SAME relative name now reads "from A" instead of
// the module dir's "from module".
node setRedirectsRead(): boolean {
  setAgentCwd(join(cwd(), "tests/agency/cwd-fixture-a"))
  const r = read("cwd-probe.txt", useAgentCwd: true) with approve
  if (r is success(v)) {
    return v.trim() == "from A"
  }
  return false
}

// Opt-in default: WITHOUT useAgentCwd, a relative read ignores the agent
// cwd even when set, and resolves against the process working directory
// ("from module" via the cwd-relative path).
node defaultIgnoresAgentCwd(): boolean {
  setAgentCwd(join(cwd(), "tests/agency/cwd-fixture-a"))
  const r = read("tests/agency/cwd-probe.txt") with approve
  if (r is success(v)) {
    return v.trim() == "from module"
  }
  return false
}

// The shell path (`bash`, whose dir arg is `cwd`, not `dir`) also honors
// the agent cwd when opted in. `pwd` prints the directory it ran in.
node bashRunsInAgentCwd(): boolean {
  setAgentCwd(join(cwd(), "tests/agency/cwd-fixture-a"))
  const r = bash("pwd", useAgentCwd: true) with approve
  return r.stdout.trim().endsWith("cwd-fixture-a")
}

// An ABSOLUTE filename bypasses the agent cwd entirely, even with opt-in.
// With the cwd pointed at a nonexistent dir, an absolute path to a real
// file is still honored.
node existsAbsoluteBypassesAgentCwd(): boolean {
  setAgentCwd("/this/does/not/exist")
  return exists(join(cwd(), "tests/agency/cwd-probe.txt"), useAgentCwd: true)
}

// Gap 3 — branch isolation, both directions: the branch INHERITS the
// parent's cwd at fork, sees its OWN write, and the parent is UNAFFECTED
// by the branch's write.
node branchInheritsAndIsolates(): boolean {
  setAgentCwd("/parent")
  const results = fork(["x"]) as item {
    const before = getAgentCwd()
    setAgentCwd("/branch")
    const after = getAgentCwd()
    return "${before}|${after}"
  }
  const parentAfter = getAgentCwd()
  return results[0] == "/parent|/branch" && parentAfter == "/parent"
}

// edit (fs.agency) resolves its relative filename against the agent cwd:
// create a scratch file under the process cwd, point the agent cwd there,
// edit by relative name, read back, and clean up.
node editResolvesRelativeToAgentCwd(): boolean {
  setAgentCwd(cwd())
  const w = write("__cwd_edit__.txt", "alpha", useAgentCwd: true) with approve
  const e = edit("__cwd_edit__.txt", [{ oldText: "alpha", newText: "beta", replaceAll: false }], useAgentCwd: true) with approve
  const r = read("__cwd_edit__.txt", useAgentCwd: true) with approve
  remove("__cwd_edit__.txt", useAgentCwd: true) with approve
  if (r is success(v)) {
    return v.trim() == "beta"
  }
  return false
}
