import { sendWithResend } from "std::email"

node main() {
  handle {
    const result = sendWithResend(
      from: "onboarding@resend.dev",
      to: "delivered@resend.dev",
      subject: "Agency CI Test",
      text: "This is an automated test from Agency CI.",
      allowList: ["delivered@resend.dev"]
    )
    if (isFailure(result)) {
      return "sendWithResend failed: " + result.error
    }
    return "email ok"
  } with (data) {
    return approve()
  }
}
