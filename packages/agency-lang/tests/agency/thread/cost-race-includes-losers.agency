import { getCost } from "std::thread"

// Pinned to the deterministic LLM provider via "useTestLLMProvider":
// true in the .test.json. SYNTHETIC_COST per llm() call lives in
// lib/runtime/deterministicClient.ts.
const DETERMINISTIC_COST = 0.000002

// Each branch performs the same number of LLM calls. Whichever branch
// resolves first wins the race; the losing branches' completed-call
// cost must still propagate back to the parent — race-loser work is
// not free.

def doNCalls(n: number): string {
  let i = 0
  while (i < n) {
    let _r = llm("call")
    i = i + 1
  }
  return "done"
}

node main() {
  let _w = race([1, 2, 3]) as k {
    return doNCalls(k)
  }

  let total = getCost()
  // If only the winner's cost (the smallest, 1 call) were counted the
  // total would be exactly DETERMINISTIC_COST. Losers do extra work, so
  // total must be strictly greater than that.
  let lostCostCounted = total > DETERMINISTIC_COST
  return "${lostCostCounted}"
}
