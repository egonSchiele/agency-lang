def getWeather(city: string): string {
  return fetch("https://weather.example.com/${city}")
}

def formatTemp(temp: number): string {
  return "${temp} degrees"
}

node main() {
  +getWeather
  +formatTemp
  forecast: string = llm("What is the weather in NYC?")

  summary: string = llm("Summarize the forecast")
}
