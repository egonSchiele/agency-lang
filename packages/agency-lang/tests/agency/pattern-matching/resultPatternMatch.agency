def tryParse(input: string): Result {
  if (input == "ok") {
    return success(42)
  }
  return failure("bad input")
}

def describe(input: string): string {
  let r = tryParse(input)
  match (r) {
    success(v) => return "got ${v}"
    failure(e) => return "err: ${e}"
  }
  return "unreachable"
}

node main() {
  let r1 = describe("ok")
  let r2 = describe("bad")
  return [r1, r2]
}
