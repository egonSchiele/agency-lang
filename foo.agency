type User = {
  name: string;
  age: number
}

user: User = { 
  name: "Alice",
  age: 30
}

node main() {
  name1 = user.name
  user.name = "Bob"
  name2 = user.name
  greet = llm("Say hi to ${name1}", { 
    model: { 
      optimizeFor: ["speed"],
      providers: ["openai", "google"]
    }
  })
  print(greet)
}