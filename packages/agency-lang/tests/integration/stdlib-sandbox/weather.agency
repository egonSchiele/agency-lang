import { weather, celsiusToFahrenheit, fahrenheitToCelsius } from "std::weather"

node main() {
  const w = weather("New York")
  if (isFailure(w)) {
    return "weather failed: " + w.error
  }

  const result = w.value
  if (result.location == "") {
    return "weather failed: empty location"
  }

  const c = fahrenheitToCelsius(32)
  if (c != 0) {
    return "fahrenheitToCelsius failed"
  }

  const f = celsiusToFahrenheit(0)
  if (f != 32) {
    return "celsiusToFahrenheit failed"
  }

  return "weather ok"
}
