import { guard } from "std::thread"

// A tiny time budget (20ms) wrapping a sleep that overruns it. The
// timer fires while the JS-bodied sleep is in flight; the in-flight
// sleep itself can't be aborted (V1 limitation), but the next runner
// step boundary after it returns sees the abort and throws
// GuardExceededError("time", ...). The stdlib guard's `try` converts
// it to a Failure with type "timeoutFailure".
node main() {
  const result = guard(time: 20ms) as {
    sleep(150ms)
    sleep(1ms)
    return "did not trip"
  }
  if (isFailure(result)) {
    // actualTime > maxTime catches a bug where actualTime is just set
    // to the limit instead of the real elapsed; actualTime > 0 alone
    // would not.
    return "tripped:${result.error.type}:${result.error.maxTime}:${result.error.actualTime > result.error.maxTime}"
  }
  return result.value
}
