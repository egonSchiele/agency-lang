// bigTool returns a 500-char result; the llm() call caps tool results
// at 50 chars. This exercises the REAL wiring: runPrompt must apply the
// cap to the tool message it feeds back to the LLM (the unit tests only
// cover the pure helper).
def bigTool(): string {
  let s = ""
  for (i in range(50)) {
    s = s + "0123456789"
  }
  return s
}

node main() {
  return llm("use the tool", { tools: [bigTool], maxToolResultChars: 50 })
}
