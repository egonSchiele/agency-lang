const log = []

def greet() {
  log.push("greet-before")
  const name = interrupt test::safe("Who do you want to say bye to?")
  log.push("greet-after-${name}")
  return "greet result"
}

def readStuff() {
  log.push("read-before")
  return interrupt test::read("Can I read a file?")
  log.push("read-after")
  return "read result"
}

def foo() {
  const res1 = greet()
  const res2 = readStuff()
  if (isFailure(res1)) {
    log.push(res1.error)
  } else {
    log.push(res1)
  }
  if (isFailure(res2)) {
    log.push(res2.error)
  } else {
    log.push(res2)
  }
  log.push("foo-done")
  return "foo result"
}

node main() {
  handle {
    const res1 = foo()
    log.push("foo returned ${res1}")
  } with (interrupt) {
    if (interrupt.kind == "test::safe") {
      return approve("Alice")
    } else if (interrupt.kind == "test::read") {
      return reject("not allowed")
    }
  }
  return log
}

node bothRejected() {
  handle {
    const res1 = foo()
    log.push("foo returned ${res1}")
  } with (interrupt) {
    if (interrupt.kind == "test::safe") {
      return reject()
    } else if (interrupt.kind == "test::read") {
      return reject("not allowed")
    }
  }
  return log
}