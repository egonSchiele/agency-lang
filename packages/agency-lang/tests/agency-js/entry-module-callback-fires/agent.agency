// Entry-module counterpart to
// `tests/agency-js/threads-fix-callback-propagation/`: that fixture
// covers a top-level `callback("onThreadEnd")` in an IMPORTED module,
// this one covers the same callback in the ENTRY module. Both fire
// (imported-module callbacks register through the cross-module
// registry), and the pair would break loudly if either direction
// regressed.
import { setMutable } from "../../helpers/mutableVar.js"

callback("onThreadEnd") as evt {
  setMutable("entry-onThreadEnd-fired", true)
  setMutable("entry-onThreadEnd-thread-id", evt.threadId)
}

node main() {
  thread {
    // Empty body — close immediately so onThreadEnd fires.
  }
}
