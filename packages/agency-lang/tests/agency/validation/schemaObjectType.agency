type Config = {
  host: string,
  port: number
}

node main() {
  const s = schema(Config)
  const goodObj = {host: "localhost", port: 8080}
  const badObj = {host: "localhost", port: "not a number"}
  const good = s.parse(goodObj)
  const bad = s.parse(badObj)
  if (isSuccess(good)) {
    if (isFailure(bad)) {
      return good.value.host
    }
  }
  return "failed"
}
