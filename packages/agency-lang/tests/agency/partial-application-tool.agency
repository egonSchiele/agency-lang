let aVal: number = 0
let bVal: number = 0

export def add(a: number, b: number): number {
  aVal = a
  bVal = b
  return a + b
}

node main() {
  const add5 = add.partial(a: 5)
  const result: number = llm("Call the add5 tool exactly once, with b set to 7. Reply with only the number the tool returned.", { tools: [add5] })
  return [aVal, bVal]
}
