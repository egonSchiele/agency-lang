import { getMutable, setMutable } from "../../helpers/mutableVar.js"

node main() {
  const cp = checkpoint()
  setMutable("log", getMutable("log", "") + "before,")
  thread {
    setMutable("log", getMutable("log", "") + "thread,")
    if (getMutable("log", "") == "before,thread,") {
      restore(cp, {})
    }
    setMutable("log", getMutable("log", "") + "done,")
  }
  return getMutable("log", "")
}
