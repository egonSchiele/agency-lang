// Project Euler Problem 10: Summation of Primes
// Find the sum of all the primes below two million.

def isPrime(n: number): boolean {
  if (n < 2) { return false }
  if (n < 4) { return true }
  if (n % 2 == 0 || n % 3 == 0) { return false }
  let i = 5
  while (i * i <= n) {
    if (n % i == 0 || n % (i + 2) == 0) { return false }
    i = i + 6
  }
  return true
}

node main() {
  let sum = 2
  let n = 3
  while (n < 2000000) {
    if (isPrime(n)) {
      sum = sum + n
    }
    n = n + 2
  }
  return sum
}
