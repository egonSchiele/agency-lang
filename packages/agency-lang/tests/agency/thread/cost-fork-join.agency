import { getCost } from "std::thread"

// Pinned to the deterministic LLM provider via "useTestLLMProvider":
// true in the .test.json. SYNTHETIC_COST per llm() call lives in
// lib/runtime/deterministicClient.ts.
const DETERMINISTIC_COST = 0.000002

node main() {
  llm("seed")
  let beforeFork = getCost()

  let branchCosts = fork([1, 2, 3, 4]) as i {
    let _r = llm("branch")
    return getCost()
  }

  let afterFork = getCost()

  let expectedBranchCost = beforeFork + DETERMINISTIC_COST
  let allBranchesMatch = branchCosts[0] == expectedBranchCost
    && branchCosts[1] == expectedBranchCost
    && branchCosts[2] == expectedBranchCost
    && branchCosts[3] == expectedBranchCost

  let expectedAfterFork = beforeFork + (4 * DETERMINISTIC_COST)
  let mainTotalMatches = afterFork == expectedAfterFork

  return "${allBranchesMatch}_${mainTotalMatches}"
}
