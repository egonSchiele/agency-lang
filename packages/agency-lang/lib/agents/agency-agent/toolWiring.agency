/*
 * Smoke tests for the Agency Agent's subagent wiring.
 *
 * These exercise the exact path that broke when `skillsDir` returned
 * several tools all named `read`: each subagent's exported tool list is
 * handed to a real `llm(...)` call. The runtime rejects duplicate tool
 * names before the request is sent, so a regression to colliding names
 * makes the corresponding `llm()` call fail and the node return "FAIL: …"
 * instead of "ok".
 *
 * Runs deterministically under AGENCY_USE_TEST_LLM_PROVIDER (see
 * toolWiring.test.json), so no API key or network is required.
 */
import { codeTools } from "./subagents/code.agency"
import { researchTools } from "./subagents/research.agency"
import { oracleTools } from "./subagents/oracle.agency"
import { explorerTools } from "./subagents/explorer.agency"

def pingWith(tools: any[]): string {
  const r = try llm("ping", { tools: tools })
  if (r is failure(e)) {
    return "FAIL: ${e}"
  }
  return "ok"
}

node codeToolsHaveUniqueNames() {
  return pingWith(codeTools)
}

node researchToolsHaveUniqueNames() {
  return pingWith(researchTools)
}

node oracleToolsHaveUniqueNames() {
  return pingWith(oracleTools)
}

node explorerToolsHaveUniqueNames() {
  return pingWith(explorerTools)
}
