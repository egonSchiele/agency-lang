/*
 * The reading specialist, as the agency agent's coordinator sees it.
 *
 * This is a router, not an agent. Both destinations are stdlib agents, so a
 * user gets the same two in their own code:
 *
 *   agencyTopic: true   -> agencyResearcherAgent  (the bundled Agency docs)
 *   agencyTopic: false  -> researcherAgent        (web, Wikipedia, URLs)
 *
 * General is the default. A general researcher asked about Agency is merely
 * less expert, while the Agency researcher asked about anything else has
 * only Agency documentation to answer from and will answer badly.
 *
 * What stays here is the agency agent's own business: the model slot the
 * user selected, a shared session, the REPL formatting rules, and the memory
 * and todo tools the agent gives its specialists.
 */
import { agencyResearcherAgent } from "std::agents/agency/researcher"
import { researcherAgent } from "std::agents/researcher"
import { memoryTools, planningTools } from "std::agents/lib/toolkits"
import { setMemoryId } from "std::memory"
import { highlight } from "std::syntax"

export static const researchTools: any[] = [
  ...memoryTools(),
  ...planningTools(),
  highlight.partial(language: "ts"),
  print,
]

static const replStyle = """Reply for a terminal REPL that renders Markdown: use headings, bullets, bold, links, and fenced code blocks. Put a blank line between a heading and whatever follows it, or the renderer truncates the rest.

Show multi-line code with `print(highlight(code))`, which writes a colored block to the user's console. Skip that for a single identifier.

For a question spanning more than two sources, call `todoWrite` first and tick each item off as you finish that source.

Keep replies brief. Cite sources. Show, do not lecture."""

export def researchAgent(userMsg: string, agencyTopic: boolean = false): string {
  """
  Answer a question that needs reading rather than writing: looking something
  up, summarizing a document, gathering background, or recalling a stored
  fact.

  @param userMsg - a message describing what needs to be found out.
  @param agencyTopic - true when the question is about the Agency language
    itself (its syntax, types, stdlib, or CLI), which routes to the agent
    that reads the bundled Agency documentation. Leave it false for every
    other subject, including questions about other languages.
  """
  setMemoryId("research")
  let result: Result<string> = success("")
  if (agencyTopic) {
    result = agencyResearcherAgent(
      question: userMsg,
      context: replStyle,
      session: "research",
      extraTools: researchTools,
    )
  } else {
    result = researcherAgent(
      task: userMsg,
      context: replStyle,
      session: "research",
      extraTools: researchTools,
    )
  }
  if (isFailure(result)) {
    return "Research did not finish: ${result.error}"
  }
  return result.value
}
