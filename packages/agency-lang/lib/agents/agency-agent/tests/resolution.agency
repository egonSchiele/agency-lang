import { Resolved } from "../lib/models.agency"
import {
  resolveSlot,
  resolveAll,
  buildLayers,
  Layer,
  Ctx,
 } from "../lib/resolution.agency"

static const CTX: Ctx = {
  provider: "anthropic",
  price: "standard"
}

def emptyLayer(name: string): Layer {
  return {
    name: name,
    perSlot: {},
    pin: null
  }
}

// Unwrap a Result<Resolved> for assertion; the sentinel will not match any
// expected output, so an unexpected failure fails the test loudly.
def unwrapResolved(result: Result<Resolved>): Resolved {
  if (isFailure(result)) {
    return {
      model: "ERR",
      provider: "ERR",
      via: "ERR"
    }
  }
  return result.value
}

// immediacy-outer: CLI global-pin beats settings per-slot (the flipped item-1 case).
node cliPinBeatsSettingsSlot(): Resolved {
  let cliLayer = emptyLayer("cli")
  cliLayer.pin = {
    model: "gpt-5.5",
    provider: ""
  }
  let settingsLayer = emptyLayer("settings")
  settingsLayer.perSlot = {
    reasoning: {
      model: "opus",
      provider: ""
    }
  }
  return unwrapResolved(
    resolveSlot(
    "reasoning",
    [emptyLayer("in-session"), cliLayer, settingsLayer],
    CTX,
  ),
  )
}

// in-session per-slot beats CLI per-slot (immediacy).
node inSessionPerSlotBeatsCli(): Resolved {
  let inSessionLayer = emptyLayer("in-session")
  inSessionLayer.perSlot = {
    main: {
      model: "a-model",
      provider: "anthropic"
    }
  }
  let cliLayer = emptyLayer("cli")
  cliLayer.perSlot = {
    main: {
      model: "b-model",
      provider: "anthropic"
    }
  }
  return unwrapResolved(resolveSlot("main", [inSessionLayer, cliLayer], CTX))
}

// in-session pin beats CLI pin.
node inSessionPinBeatsCliPin(): Resolved {
  let inSessionLayer = emptyLayer("in-session")
  inSessionLayer.pin = {
    model: "a-model",
    provider: "anthropic"
  }
  let cliLayer = emptyLayer("cli")
  cliLayer.pin = {
    model: "b-model",
    provider: "anthropic"
  }
  return unwrapResolved(resolveSlot("main", [inSessionLayer, cliLayer], CTX))
}

// within settings: per-slot beats pin.
node settingsPerSlotBeatsSettingsPin(): Resolved {
  let settingsLayer = emptyLayer("settings")
  settingsLayer.pin = {
    model: "pin-model",
    provider: "anthropic"
  }
  settingsLayer.perSlot = {
    main: {
      model: "slot-model",
      provider: "anthropic"
    }
  }
  return unwrapResolved(
    resolveSlot(
    "main",
    [emptyLayer("in-session"), emptyLayer("cli"), settingsLayer],
    CTX,
  ),
  )
}

// no layer set: built-in default; empty provider inherits ctx.
node fallsToBuiltinDefault(): Resolved {
  return unwrapResolved(
    resolveSlot(
    "main",
    [emptyLayer("in-session"), emptyLayer("cli"), emptyLayer("settings")],
    CTX,
  ),
  )
}

// resolveAll propagates failure for a default-less provider with no override.
node resolveAllPropagatesFailure(): boolean {
  const ctx: Ctx = {
    provider: "litellm",
    price: "standard"
  }
  return isFailure(
    resolveAll(
    [emptyLayer("in-session"), emptyLayer("cli"), emptyLayer("settings")],
    ctx,
  ),
  )
}

// back-compat parity: built-in default equals planModels for anthropic main.
node parityMainAnthropic(): Resolved {
  return unwrapResolved(
    resolveSlot(
    "main",
    [emptyLayer("in-session"), emptyLayer("cli"), emptyLayer("settings")],
    CTX,
  ),
  )
}

// buildLayers: CLI --model gpt-5.5 over settings slots.reasoning=opus gives gpt-5.5.
node buildLayersImmediacyOuter(): Resolved {
  const layers = buildLayers(
    "",
    {},
    "gpt-5.5",
    {},
    {
    slots: {
      reasoning: "opus"
    }
  },
    ["anthropic", "openai"],
    false,
  )
  const all = resolveAll(layers, CTX)
  if (isFailure(all)) {
    return {
      model: "ERR",
      provider: "ERR",
      via: "ERR"
    }
  }
  const reasoning = all.value["reasoning"]
  if (reasoning == null) {
    return {
      model: "ERR",
      provider: "ERR",
      via: "ERR"
    }
  }
  return reasoning
}


// Rule 1: a derived slot always parses its provider prefix, even when the
// session provider is established. buildLayers with providerEstablished
// true must still split the embedding value.
node derivedSlotAlwaysParsesPrefix(): Resolved {
  const layers = buildLayers(
    "",
    {},
    "",
    {},
    {
    slots: {
      embedding: "openai/text-embedding-3-small"
    }
  },
    ["anthropic", "openai", "google"],
    true,
  )
  return unwrapResolved(resolveSlot("embedding", layers, CTX))
}

// Rule 2: a derived slot with no provider prefix resolves with an EMPTY
// provider instead of inheriting the ctx provider.
node derivedSlotNeverInheritsProvider(): Resolved {
  const layers = buildLayers(
    "",
    {},
    "",
    {},
    {
    slots: {
      embedding: "text-embedding-3-small"
    }
  },
    ["anthropic", "openai", "google"],
    false,
  )
  return unwrapResolved(resolveSlot("embedding", layers, CTX))
}

// Rule 3: a global pin resolves the chat slots but never the embedding
// slot, which falls through to the built-in empty derived value.
node pinSkipsDerivedSlot(): string {
  let cliLayer = emptyLayer("cli")
  cliLayer.pin = {
    model: "claude-opus-4-8",
    provider: ""
  }
  const main = unwrapResolved(resolveSlot("main", [cliLayer], CTX))
  const embedding = unwrapResolved(resolveSlot("embedding", [cliLayer], CTX))
  return "${main.model}/${embedding.model}|${embedding.via}"
}
