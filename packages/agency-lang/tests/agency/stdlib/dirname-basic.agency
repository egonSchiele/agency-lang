import { exists } from "std::shell"
import { join } from "std::path"

node main() {
  let d = __dirname
  // __dirname is a non-empty absolute path holding this file's compiled
  // module — so the fixture file co-located with this .agency should
  // resolve and exist on disk.
  return {
    nonEmpty: d != "",
    fixtureExists: exists(join(d, "dirname-fixture.txt"))
  }
}
