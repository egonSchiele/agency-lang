import { map, filter } from "std::array"
import { verifierAgent } from "std::agents/verifier"
import { Feedback } from "std::agents/lib/feedback"

/*
 * Verify subagent: a thin adapter over `std::agency::verify` for the code
 * agent's one-shot loop. The verification logic now lives in std::agency
 * (lifted so stdlib agents can share it); this module converts its
 * `Result<Feedback[]>` into the `Verdict` shape the code-agent loop matches on.
 */

// Structured verdict the code-agent loop matches on.
export type Verdict = {
  satisfied: boolean;
  gaps: string[];
}

// Render gaps as a bullet list for the re-prompt. Small, pure, testable.
export def renderGaps(gaps: string[]): string {
  return map(gaps, \g -> "- ${g}").join("\n")
}

// Unwrap a `try verify(...)` Result to a plain Verdict, failing OPEN on any
// Failure. Verification can only help, never block. Kept as a plain `def` so
// the caller's loop body stays free of binder-in-`if` patterns (which the
// stepped-loop codegen doesn't handle).
export def unwrapVerdict(r: Result<Verdict>): Verdict {
  return match (r) {
    success(v) => v
    failure(err) => failOpenVerdict(err)
  }
}

// The fail-open verdict, carrying the failure message for observability.
def failOpenVerdict(err: string): Verdict {
  return { satisfied: true, gaps: ["verification could not run: ${err}"] }
}

// One gap string per ERROR finding (error:false observations are dropped, and
// a verifier that could not run fails open to no gaps).
def errorGaps(fb: Result<Feedback[]>): string[] {
  return match (fb) {
    failure(_) => []
    success(items) => map(filter(items, \f -> f.error), \f -> f.feedback)
  }
}

export def verify(originalUserMsg: string, criteria: string[] = []): Verdict {
  """
  Fresh-eyes verification of the code agent's work: delegates to
  `verifierAgent` (which inspects the working directory and runs the artifact
  against the task's own success criteria) and converts its findings into a
  Verdict, one gap per error finding.

  @param originalUserMsg - the original task description to verify against.
  @param criteria - authoritative acceptance criteria to check, or [] to
    derive them from the task alone.
  """
  const gaps = errorGaps(verifierAgent(originalUserMsg, criteria: criteria))
  return { satisfied: gaps.length == 0, gaps: gaps }
}
