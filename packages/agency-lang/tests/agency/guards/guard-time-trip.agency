import { guard } from "std::thread"

// A tiny time budget (20ms) wrapping a sleep that overruns it. The
// timer fires while the JS-bodied sleep is in flight; sleep is
// abortable, so it wakes promptly on the guard's abort signal. The
// next runner step boundary then throws GuardExceededError("time",
// ...). The stdlib guard's `try` converts it to a Failure with type
// "timeoutFailure". We assert actualTime is a real elapsed
// measurement (at least half the budget) rather than a 0/sentinel
// value; see the comment on the assertion below for why the bound is
// deliberately loose.
node main() {
  const result = guard(time: 20ms) as {
    sleep(150ms)
    sleep(1ms)
    return "did not trip"
  }
  if (isFailure(result)) {
    // actualTime is measured with performance.now(), while the guard's
    // timer fires off libuv's coarser millisecond clock, and loaded CI
    // runners add scheduling latency on top — the two readings can
    // disagree by MORE than the 2ms this test used to allow (issue
    // #467: it flaked at exactly that boundary). The property worth
    // asserting is that actualTime is a real measurement rather than a
    // 0/sentinel value, so require it to reach half the budget: immune
    // to any plausible clock skew, still catches a broken measurement.
    return "tripped:${result.error.type}:${result.error.maxTime}:${result.error.actualTime >= result.error.maxTime / 2}"
  }
  return result.value
}
