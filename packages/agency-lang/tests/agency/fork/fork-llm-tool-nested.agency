def confirmItem(item: string): string {
  interrupt("approve ${item}?")
  return "confirmed: ${item}"
}

/** Search for items matching a query. Returns an array of result strings. */
def search(query: string): string[] {
  let results = fork(["${query}-1", "${query}-2"]) as item {
    return confirmItem(item)
  }
  return results
}

type Response = {
  searches: string[]
}

node main() {
  const result: Response = llm("Please search for both 'cats' and 'dogs'. Return the searches field with all the search results combined into a single flat array.", { tools: [search] })
  print("Final result:", JSON.stringify(result, null, 2))
  return result.searches
}
