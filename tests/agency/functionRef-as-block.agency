def double(x: number): number {
  return x * 2
}

def applyToAll(items: number[], transform: (number) => number): number[] {
  const result: number[] = []
  for (item in items) {
    result.push(transform(item))
  }
  return result
}

node main() {
  const result = applyToAll([1, 2, 3], double)
  return result[0] + result[1] + result[2]
}
