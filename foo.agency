class Parser {
  prefix: string

  parse(input: string): Result {
    if (input == "") {
      return failure("empty input")
    }    let p = this.prefix    return success(p + input)  }
}

def exclaim(s: string): string {
  return s + "!"
}

node main() {
  let p = new Parser(>>)
  let r1 = try
p.parse("hello") |> exclaim
  let r2 = try
p.parse("") |> exclaim
  return { 
    r1: r1,
    r2: r2
  }
}