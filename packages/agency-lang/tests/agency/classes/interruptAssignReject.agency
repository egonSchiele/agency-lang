class Checker {
  label: string

  verify(): string {
    let l = this.label
    const result = interrupt("Approve " + l + "?")
    return "got: " + result
  }
}

node main() {
  let checker = new Checker("action")
  let result = checker.verify()
  if (isFailure(result)) {
    return "rejected"
  }
  return result
}
