/*
 * The explorer, as the agency agent's coordinator sees it.
 *
 * The agent itself lives in std::agents/explorer, so users get the same
 * surveyor in their own agents. This wrapper supplies the two things that
 * are the agency agent's business and not the stdlib's: the slow-model slot
 * the user selected, and a shared session so repeated surveys in one run
 * continue a conversation rather than starting cold.
 *
 * The docstring below is what the coordinator reads when deciding whether to
 * call this, so it is written for routing, not for the agent's own behavior.
 */
import { explorerAgent as stdExplorerAgent } from "std::agents/explorer"

import { getSlowModel, getSlowProvider } from "../shared.agency"

export def explorerAgent(userMsg: string): Result<string> {
  """
  Ask the explorer — a read-only researcher on a stronger
  reasoning model — to produce a broad, synthesizing answer about
  the codebase or the bundled Agency docs.

  Use this when the user asks a question whose answer requires
  **reading many files and synthesizing**:

  - "Summarize the Agency docs"
  - "What are the main features of X?"
  - "Give me a tour of module Y"
  - "How does Z work across the codebase?"
  - "Walk me through the compilation pipeline"

  Do NOT use this for:
  - Targeted lookups (use `codeAgent` or just `grep`)
  - Plan critique or bug diagnosis (use `oracleAgent`)
  - External / web research (use `researchAgent`)

  Pass a self-contained question — the explorer starts fresh and
  does not see your conversation. Be explicit about the scope you
  want covered ("all of docs/site/guide/", "the lib/parsers/
  module") and the level of detail expected.

  @param userMsg - the question, with the scope of coverage you
    want covered
  """
  // Returned as a Result rather than a string saying the explorer failed: the
  // tool loop only recognizes a failure it can see, and a failure worded as
  // prose invites the coordinator to ask the same question again.
  return stdExplorerAgent(
    question: userMsg,
    model: getSlowModel(),
    provider: getSlowProvider(),
    session: "explorer",
  )
}
