def run(b: () -> void) {
  b()
}

node main(): number {
  let total = 0
  run() as {
    let a = 1
    run() as {
      let b = 10
      run() as {
        a = a + 100      // writes outermost block's a (depth 2)
        b = b + 20       // writes middle block's b (depth 1)
      }
      total = a + b      // 101 + 30
    }
  }
  return total
}
