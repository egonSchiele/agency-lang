type PairwiseWinner = "A" | "B" | "tie"
type PairwiseConfidence = "low" | "medium" | "high"

type PairwiseJudgeResult = {
  winner: PairwiseWinner
  confidence: PairwiseConfidence
  reasoning: string
}

node judgePairwise(goal: string, responseA: string, responseB: string): PairwiseJudgeResult {
  result: PairwiseJudgeResult = llm("You are an impartial judge comparing two agent responses to the same task.

Goal:
${goal}

Response A:
${responseA}

Response B:
${responseB}

Decide which response better meets the goal. Pick \"A\", \"B\", or \"tie\". Be honest about confidence: confidence must be exactly one of \"low\", \"medium\", or \"high\". \"tie\" is the right call when responses are genuinely indistinguishable, not a way to dodge the question. Give a brief reasoning (1-3 sentences) that cites specifics from each response.")

  return result
}
