def confirmItem(item: string): string {
  interrupt("approve ${item}?")
  return "confirmed: ${item}"
}

node main() {
  const flag = false
  let results: string[] = []
  if (flag) {
    results = ["never"]
  } else {
    results = fork(["x", "y"]) as item {
      return confirmItem(item)
    }
  }
  return results
}
