
let firedOuter: number = 0
let firedInner: number = 0
let caughtKinds: string = ""

def doWork(): string {
  return "x"
}

// Two scoped callbacks on the same hook, both registered inside
// handle blocks, both throw interrupts. The key invariant: BOTH
// callbacks must fire — an interrupt raised by one callback must not
// prevent later callbacks from running. Each callback increments its
// own counter BEFORE throwing so we can prove it ran without depending
// on the exact handler-cascade semantics.
def outer(block: any) {
  callback("onFunctionEnd") as data {
    if (data.functionName == "doWork") {
      firedOuter = firedOuter + 1
      interrupt myapp::outerKind("from outer", data)
    }
  }
  block()
}

def inner(block: any) {
  callback("onFunctionEnd") as data {
    if (data.functionName == "doWork") {
      firedInner = firedInner + 1
      interrupt myapp::innerKind("from inner", data)
    }
  }
  block()
}

node main() {
  handle {
    outer() {
      handle {
        inner() {
          doWork()
        }
      } with (intr) {
        caughtKinds = caughtKinds + intr.kind + ","
        return approve()
      }
    }
  } with (intr) {
    caughtKinds = caughtKinds + intr.kind + ","
    return approve()
  }
  return [firedOuter, firedInner]
}
