def greet(name: string) {
  return interrupt("Are you sure you want to greet ${name}?")
  return "Hello, ${name}!"
}

node main() {
  const name = "Alice"
  handle {
    const greeting = greet(name)
    print(greeting)
  } with (msg) {
    print("Caught interrupt with message: ${msg}")
    return approve()
  }
}