def confirmItem(item: string): string {
  interrupt("approve ${item}?")
  return "ok ${item}"
}

def runBatch(prefix: string): string[] {
  let results = fork(["1", "2"]) as i {
    return confirmItem("${prefix}-${i}")
  }
  return results
}

node main() {
  let result = race(["a", "b"]) as p {
    return runBatch(p)
  }
  return result
}
