{
  "compilerOptions": {
    "outDir": "./stdlib",
    "rootDir": "./stdlib",
    "module": "NodeNext",
    "target": "ESNext",
    "moduleResolution": "NodeNext",
    "declaration": false,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["stdlib/**/*.ts"],
  "exclude": [
    "node_modules",
    "stdlib/index.ts",
    "stdlib/**/*.test.ts",
    "stdlib/**/__tests__/**"
  ]
}
