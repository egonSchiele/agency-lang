import { map } from "std::array"
def riskyOp(label: string): string {
  interrupt("approve ${label}?")
  return "confirmed: ${label}"
}

node main() {
  let results = fork(["a", "b"]) as item {
    let r = riskyOp(item) with reject
    return r
  }
  const results2 = map(results) as result {
    if (isFailure(result)) {
      return { 
        success: false,
        error: result.error
      }
    }
    return result
  }
  return results2
}
