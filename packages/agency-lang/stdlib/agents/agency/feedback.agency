import { TypeCheckReport, typecheck } from "std::agency"

def parseFeedback(source: string): Result<Feedback[]> {
  """
  Use this to give feedback on whether the source code is syntactically valid.
  """
  const result = try _parseAST(source)
  if (result is failure(err)) {
    return success([{
      error: true,
      feedback: "Parse error: ${err}"
    }])
  }
  return success([])
}

// Report -> findings, separated from typecheckFeedback so writeAgency
// can format an already-computed report without re-checking.
def reportFeedback(report: TypeCheckReport): Feedback[] {
  const feedback: Feedback[] = []
  for (error in report.errors) {
    feedback.push({
      error: true,
      feedback: "Error: ${error.message}"
    })
  }
  for (warning in report.warnings) {
    feedback.push(
      {
      error: false,
      feedback: "Warning: ${warning.message}"
    },
    )
  }
  return feedback
}

def typecheckFeedback(source: string): Result<Feedback[]> {
  """
  Use this to give feedback on whether the source code is type-correct.
  """
  const result = typecheck(source)
  if (result is failure(err)) {
    return success(
      [{
      error: true,
      feedback: "Typecheck failed: ${err}"
    }],
    )
  }
  return success(reportFeedback(result.value))
}

/** Basic LLM-as-a-judge feedback. Given a task + some source code,
does the code accomplish the task? */
def llmFeedback(source: string, task: string): Result<Feedback[]> {
  """
  Use this to give feedback on whether the source code accomplishes the task.
  """

  const prompt = """You are reviewing Agency-language code.
The code was written for this task:
<task>
${task}
</task>

<code>
${source}
</code>

Return a list of feedback items. Set error=true only if the code does
not accomplish the task. Keep feedback brief and concrete."""

  thread(label: "std::agents/feedback/llmFeedback") {
    const items: Feedback[] = llm(prompt)
    return success(items)
  }
}

/**
Specifically for getting feedback on Agency source code.
Runs all the other feedback functions and merges their results.
If the task is provided, also runs llmFeedback.
*/
export def agencyFeedback(
  source: string,
  task: string | null = "",
): Result<Feedback[]> {
  """
  Review Agency source code.

  @param source - Agency source code as a string
  @param task - Optional description of what the code should do
  """
  let feedback: Result<Feedback[]> = success([])
  feedback = mergeFeedback(feedback, parseFeedback(source))
  feedback = mergeFeedback(feedback, typecheckFeedback(source))
  if (task != "" && task != null) {
    feedback = mergeFeedback(feedback, llmFeedback(source, task))
  }
  if (feedback is success(items)) {
    if (items.length == 0) {
      const noErrors = {
        error: false,
        feedback: "Code is valid with no errors or warnings."
      }
      return success([noErrors])
    }
  }
  return feedback
}
