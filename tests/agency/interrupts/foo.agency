let globalVar = 0

export def increment() {
  globalVar = globalVar + 1
}

export def getGlobal() {
  return globalVar
}

export def funcThrowsInterrupt(val: number) {
  const foo = val
  const bar = 10
  return interrupt("Interrupting from funcThrowsInterrupt")
  return {
    foo: foo,
    bar: bar
  }
}