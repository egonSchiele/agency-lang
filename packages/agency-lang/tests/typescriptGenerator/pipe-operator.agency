def double(x: number): number {
  return x * 2
}

def multiply(a: number, b: number): number {
  return a * b
}

def safeDivide(a: number, b: number): Result {
  if (b == 0) {
    return failure("division by zero")
  }
  return success(a / b)
}

node main() {
  let r1 = success(5) |> double
  let r2 = success(5) |> multiply.partial(a: 10)
  let r3 = success(10) |> double |> multiply.partial(a: 3)
  let r4 = failure("nope") |> double
  let r5 = success(10) |> safeDivide.partial(b: 2)
}
