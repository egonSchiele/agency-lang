// Nested-in-object: result pattern inside an object match pattern.
def describe(box: any): string {
  return match (box) {
    { result: success(v) } => "ok ${v}"
    { result: failure(e) } => "err ${e}"
    _ => "other"
  }
}

node main() {
  let b1 = { result: success(7) }
  let b2 = { result: failure("nope") }
  return [describe(b1), describe(b2)]
}
