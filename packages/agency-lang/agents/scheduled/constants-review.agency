import { grep } from "std::shell"
import { exit } from "std::system"
import { pkgDir, repoRoot, stamp, openPr, openPrExists, ensureDir } from "./pr.agency"

/** @module
  Weekly maintenance agent: find "magic" constants scattered across the
  codebase that should be centralized in `lib/constants.ts`.

  It reads the current `lib/constants.ts` (to learn the house rule and avoid
  re-suggesting values already centralized), then uses read-only search to hunt
  for literal values that are duplicated across files or that callers need to
  recognize/override. It opens a PR containing a findings report; it does NOT
  move any constants itself — a human decides.

  Security posture: runs non-interactively on GitHub Actions with a least-
  privilege `GITHUB_TOKEN`. The LLM is handed ONLY read-only tools (`read`,
  `grep`); it cannot write files, run shell commands, or make network calls. The
  agent itself performs every git action. The report is model-generated text, so
  a prompt-injection could plant misleading suggestions in it; the human PR
  review is the mitigation. See `pr.agency`.
*/

node main() {
  const root = repoRoot()
  const pkg = pkgDir()

  // Read the current constants file with the typed `read` tool (not a raw `cat`).
  const constsResult = read("lib/constants.ts", pkg) with approve
  let consts = ""
  if (constsResult is success(text)) {
    consts = text
  } else {
    print("Failed to read lib/constants.ts. Aborting.")
    exit(1) with approve
  }

  // Skip early (before any LLM spend) if last week's PR is still open.
  const branchPrefix = "chore/constants-review-"
  if (openPrExists(root, branchPrefix)) {
    print("An open constants-review PR already exists; skipping this run.")
    return
  }

  const rubric = """You maintain a TypeScript codebase (a programming language called Agency). The file lib/constants.ts is the single home for project-wide 'magic values': a literal (string or number) belongs there when it is used in more than one file, or when callers need to recognize or override it. Your job: find literals in the codebase that meet that bar but are NOT yet in lib/constants.ts, and would be clearer if centralized. Use the read and grep tools (search paths relative to the repository root; the code lives under packages/agency-lang/lib). Concentrate on lib/. Good candidates: the same string or number literal hardcoded in several files (env-var names, model names, default thresholds, timeouts, magic sentinels, file/dir names used as a cross-process contract). Ignore: values used in exactly one place, test fixtures, obvious loop bounds like 0/1, and anything already exported from lib/constants.ts. For each candidate report a markdown bullet: the literal value, every file:line where it appears, and a one-line reason it should be centralized. If you find nothing worth moving, reply with exactly the text NO ISSUES and nothing else."""

  const prompt = """${rubric}

Current lib/constants.ts (do NOT re-suggest anything already here):

${consts}"""

  let finding = ""
  thread(session: "constants-review") {
    finding = llm(prompt, tools: [read, grep]) with approve
  }

  // Exact match: the rubric promises exactly `NO ISSUES`, so a reply that only
  // contains the phrase alongside real findings is still treated as a finding.
  if (finding.trim() == "NO ISSUES") {
    print("Reviewed the codebase; no un-centralized constants worth moving. Nothing to do.")
    return
  }

  const report = """# Constants centralization review

Automated weekly scan for 'magic' literals that are duplicated across files or that callers must recognize, and that would be clearer in `lib/constants.ts`. Each item is a model-generated suggestion for a human to confirm; nothing has been moved.

${finding}
"""

  const reportDir = "${pkg}/docs/dev/_reports"
  ensureDir(reportDir)
  const writeResult = write("constants-review.md", report, dir: reportDir) with approve
  if (writeResult is failure(err)) {
    print("Failed to write the report: ${err}. Aborting.")
    exit(1) with approve
  }

  const branch = "${branchPrefix}${stamp()}"
  const body = """Automated: weekly scan for magic constants that should live in `lib/constants.ts`.

This PR adds/updates `docs/dev/_reports/constants-review.md` with candidate literals to centralize. It does NOT move any constants. Please confirm each suggestion and make the real changes as you see fit.

Opened by the weekly `constants-review` scheduled agent."""
  const url = openPr(
    root,
    branch,
    ["packages/agency-lang/docs/dev/_reports/constants-review.md"],
    "chore: weekly constants-centralization report",
    "Weekly constants-centralization report",
    body,
  )
  if (url == "") {
    print("No changes to commit; no PR opened.")
  } else {
    print("Opened PR: ${url}")
  }
}
