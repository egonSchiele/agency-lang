// Pipe-into-method-ref through an object value.
//
// Previously this fixture exercised the same pipe shape against a class
// method. Classes were removed, so we get the same coverage by storing
// a partially-applied function on a plain-object "receiver" — the codegen
// for `obj.method` as a pipe stage is the field/method-ref path either
// way.

type Math = {
  factor: number,
  multiply: (number) => Result
}

def multiplyBy(factor: number, x: number): Result {
  return success(x * factor)
}

def divideBy(x: number, divisor: number): Result {
  if (divisor == 0) {
    return failure("division by zero")
  }
  return success(x / divisor)
}

def makeMath(factor: number): Math {
  return {
    factor: factor,
    multiply: multiplyBy.partial(factor: factor)
  }
}

node main() {
  let math = makeMath(2)

  // pipe into a method-ref (object field whose value is a function)
  let r1 = success(5) |> math.multiply

  // pipe into function with partial application
  let r2 = success(10) |> divideBy.partial(divisor: 2)

  // chaining multiple method calls
  let r3 = success(3) |> math.multiply |> math.multiply

  // short-circuit on failure
  let r4 = success(10) |> divideBy.partial(divisor: 0) |> math.multiply

  return {
    r1: r1.value,
    r2: r2.value,
    r3: r3.value,
    r4Failed: isFailure(r4),
    r4Error: r4.error
  }
}
