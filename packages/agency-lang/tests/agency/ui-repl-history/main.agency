import { repl, setScriptedKeys } from "std::ui"

let submits: string[] = []

def status(): { left: string; right: string } {
  return { left: "", right: "" }
}
def onSubmitPrompt(submittedPrompt: string): boolean {
  submits.push(submittedPrompt)
  // Exit after 3 submits.
  return submits.length < 3
}

node main(): string {
  // Sequence:
  //   a, enter      -> submits[0] == "a"
  //   b, enter      -> submits[1] == "b"
  //   up, enter     -> submits[2] == "b" (recalled via history up)
  setScriptedKeys([
    { key: "a" }, { key: "enter" },
    { key: "b" }, { key: "enter" },
    { key: "up" }, { key: "enter" }
  ])
  repl(prompt: "> ", status: status,
       paletteCommands: {}, onSubmit: onSubmitPrompt)
  if (submits.length != 3) { return "FAIL: count" }
  if (submits[0] != "a")   { return "FAIL: [0]" }
  if (submits[1] != "b")   { return "FAIL: [1]" }
  if (submits[2] != "b")   { return "FAIL: [2]" }
  return "pass"
}
