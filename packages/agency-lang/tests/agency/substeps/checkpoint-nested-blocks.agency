import { getMutable, setMutable } from "../../helpers/mutableVar.js"

node main() {
  const cp = checkpoint()
  setMutable("log", getMutable("log", "") + "start,")
  for (i in range(2)) {
    if (i == 0) {
      setMutable("log", getMutable("log", "") + "a,")
    } else {
      setMutable("log", getMutable("log", "") + "b,")
    }
  }
  if (getMutable("log", "") == "start,a,b,") {
    restore(cp, {})
  }
  return getMutable("log", "")
}
