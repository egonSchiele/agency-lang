/*
 * Tests that the agent's per-message logic is callable without the REPL.
 *
 * `agentReply` is the seam extracted from `main`/`_runTurn`: it takes a
 * user message and returns the agent's reply, with no terminal, no user
 * input, and no policy handler required. That's what makes the agent
 * testable — this harness just calls it with the deterministic LLM
 * provider (see agentTurn.test.json) and checks the reply comes back.
 */
import {
  agentReply,
  switchModel,
  reactToSlotChange,
  Session,
 } from "../agent.agency"
import { knownProviders, Resolved } from "../lib/models.agency"
import {
  resolveAll,
  buildLayers,
  Ctx,
  SlotChange,
 } from "../lib/resolution.agency"
import { saveSettings } from "../lib/settings.agency"
import { applyResolved, getResolvedSlots, promoteAll } from "../shared.agency"

node respondsToAMessage(): boolean {
  const reply = agentReply("hello")
  return reply == "Hi from the agent!"
}

// End-to-end of the wired apply/read path (env-independent: empty settings, no
// resolveDetected). Proves applyResolved/getResolvedSlots match the built-in
// (planModels) defaults for anthropic. Back-compat guard (review #4).
node applyResolvedSetsSlots(): string {
  const ctx: Ctx = {
    provider: "anthropic",
    price: "standard"
  }
  const layers = buildLayers("", {}, "", {}, {}, knownProviders(), false)
  const all = resolveAll(layers, ctx)
  if (isFailure(all)) {
    return "FAIL"
  }
  applyResolved(promoteAll(all.value))
  const slots = getResolvedSlots()
  const main = slots["main"]
  const reasoning = slots["reasoning"]
  if (main == null || reasoning == null) {
    return "MISSING"
  }
  return "${main.model}|${reasoning.model}|${reasoning.provider}"
}

// The agent promotes openai to openai-responses on the override path too.
node promotesOpenaiProvider(): string {
  const slots: Record<string, Resolved> = {
    main: {
      model: "gpt-4o",
      provider: "openai",
      via: "x"
    }
  }
  const promoted = promoteAll(slots)
  const mainSlot = promoted["main"]
  if (mainSlot == null) {
    return "MISSING"
  }
  return mainSlot.provider
}

static const SWITCH_CTX: Ctx = {
  provider: "anthropic",
  price: "standard"
}
static const SWITCH_BEFORE: Record<string, Resolved> = {
  main: {
    model: "claude-sonnet-4-6",
    provider: "anthropic",
    via: "x"
  },
  reasoning: {
    model: "claude-opus-4-8",
    provider: "anthropic",
    via: "x"
  },
  embedding: {
    model: "",
    provider: "anthropic",
    via: "x"
  }
}

def freshSession(): Session {
  return {
    pin: "",
    slots: {}
  }
}

def slotModel(slots: Record<string, Resolved>, slot: string): string {
  const value = slots[slot]
  if (value == null) {
    return "MISSING"
  }
  return value.model
}

// A bare /model spec sets the in-session global pin, so all slots become gpt-5.5
// (pin wins over any on-disk settings, so no clear needed).
node switchPinsAllSlots(): string {
  const out = switchModel(freshSession(), "gpt-5.5", SWITCH_CTX, SWITCH_BEFORE)
  return "${slotModel(out.resolved, "main")}|${slotModel(out.resolved, "reasoning")}"
}
// A slot=model spec sets only that slot in-session; main keeps its built-in
// default (doesn't collapse routing). Clear settings for determinism.
node switchPerSlotOnly(): string {
  saveSettings({}) with approve
  const out = switchModel(
    freshSession(),
    "reasoning=claude-opus-4-8",
    SWITCH_CTX,
    SWITCH_BEFORE,
  )
  return "${slotModel(out.resolved, "reasoning")}|${slotModel(out.resolved, "main")}"
}
// Only the changed slot is reported in `changes`.
node switchReportsChanges(): number {
  saveSettings({}) with approve
  const out = switchModel(freshSession(), "main=gpt-4o", SWITCH_CTX, SWITCH_BEFORE)
  return out.changes.length
}
// switchModel copies prior; it must not mutate the caller's session.
node switchDoesNotMutatePrior(): string {
  const prior = freshSession()
  switchModel(prior, "gpt-5.5", SWITCH_CTX, SWITCH_BEFORE)
  return prior.pin
}

// An unknown slot (e.g. a typo) is rejected: the assignment is unchanged and
// nothing is reported as changed.
node switchRejectsUnknownSlot(): string {
  saveSettings({}) with approve
  const out = switchModel(freshSession(), "resoning=opus", SWITCH_CTX, SWITCH_BEFORE)
  return "${slotModel(out.resolved, "main")}|${out.changes.length}"
}

// A main-slot provider change emits the recall notice (and pauses memory).
node reactNotifiesOnMainProviderChange(): boolean {
  const change: SlotChange = {
    slot: "main",
    before: {
      model: "claude-sonnet-4-6",
      provider: "anthropic",
      via: "x"
    },
    after: {
      model: "gpt-5.5",
      provider: "openai-responses",
      via: "y"
    }
  }
  return reactToSlotChange(change)
}
// A same-provider change does not; recall is unaffected.
node reactSilentOnSameProvider(): boolean {
  const change: SlotChange = {
    slot: "main",
    before: {
      model: "claude-sonnet-4-6",
      provider: "anthropic",
      via: "x"
    },
    after: {
      model: "claude-opus-4-8",
      provider: "anthropic",
      via: "y"
    }
  }
  return reactToSlotChange(change)
}


import { modelChoiceItems, parseModelsFilters } from "../agent.agency"
import { hostedModelInfo } from "std::llm"

// Built from the real baked catalog, so a bare filter yields items.
node modelItemsNonEmpty(): boolean {
  return modelChoiceItems({}).length > 0
}

// The provider filter must ACTUALLY narrow: every returned item resolves to an
// anthropic model (via hostedModelInfo on the item key). If modelChoiceItems
// ignored the filter, a non-anthropic item would appear and this returns false
// — the thing a plain length>0 check cannot catch.
node modelItemsFilterOnlyAnthropic(): boolean {
  const items = modelChoiceItems({ provider: "anthropic" })
  if (items.length == 0) {
    return false
  }
  for (item in items) {
    const info = hostedModelInfo(item.key)
    if (info == null) {
      return false
    }
    if (info.provider != "anthropic") {
      return false
    }
  }
  return true
}

// ...and the filtered set is a strict subset of the whole catalog.
node modelItemsFilterNarrows(): boolean {
  return modelChoiceItems({ provider: "anthropic" }).length < modelChoiceItems({}).length
}

// The item key is the model name (what switchModel receives); guards a
// key/label swap. hostedModelInfo resolving it confirms it is a real name.
node modelItemKeyIsModelName(): boolean {
  const items = modelChoiceItems({ provider: "anthropic" })
  return hostedModelInfo(items[0].key) != null
}

// `/models` arg parsing (extracted so it is unit-testable, no magic offset).
node parseModelsBareIsEmpty(): boolean {
  const filters = parseModelsFilters("/models")
  return filters.provider == null
}
node parseModelsProviderArg(): boolean {
  const filters = parseModelsFilters("/models anthropic")
  return filters.provider == "anthropic"
}
node parseModelsTrailingSpaceIsEmpty(): boolean {
  const filters = parseModelsFilters("/models   ")
  return filters.provider == null
}
