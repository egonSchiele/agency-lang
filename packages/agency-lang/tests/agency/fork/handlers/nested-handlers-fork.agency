def innerInterrupt(item: string): string {
  interrupt("approve ${item}?")
  return "done: ${item}"
}

node main() {
  handle {
    handle {
      let results = fork(["a", "b"]) as item {
        return innerInterrupt(item)
      }
      return results
    } with (interrupt) {
      if (interrupt.message == "approve a?") {
        return approve()
      }
      return propagate()
    }
  } with (interrupt) {
    return approve()
  }
}
