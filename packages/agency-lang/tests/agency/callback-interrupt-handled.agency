import { callback } from "std::agency"

let log: string = ""

def guard(block: any) {
  callback("onFunctionEnd") as data {
    interrupt myapp::guarded("function ended", data)
  }
  block()
}

def doWork(): string {
  return "x"
}

node main() {
  handle {
    guard() {
      doWork()
    }
  } with (intr) {
    log = log + "caught:" + intr.kind + ","
    return approve()
  }
  return log
}
