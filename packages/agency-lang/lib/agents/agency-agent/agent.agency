import { typecheck } from "std::agency"
import { edit, multiedit } from "std::fs"
import { Policy, checkPolicy } from "std::policy"
import { skillsDir } from "std::skills"
import { highlight } from "std::syntax"
import { cwd } from "std::system"
import { systemMessage } from "std::thread"
/*
 * Agency Agent — helps users create and modify Agency code.
 *
 * Features:
 * - Doc-as-skills: bundles `docs/site/guide` (copied to
 *   `dist/lib/agents/docs/guide` at build time, see makefile) and
 *   exposes each Markdown file as a skill the LLM can read on demand.
 * - Typechecking: the LLM can call `typecheck` on any source it
 *   generates to verify the code before showing it to the user.
 * - File I/O tools: `read`, `write`, `edit` for actually creating /
 *   editing `.agency` files.
 * - Interactive policy: every interrupt the LLM raises pops a
 *   prompt with approve / reject / always-approve / always-reject.
 *   "Always" decisions are recorded in a per-run Policy and replayed
 *   automatically for the rest of the session via `checkPolicy`.
 *
 * Run: `pnpm run agency run dist/lib/agents/agency-agent/agent.agency`
 *      (run from `dist/` so the bundled docs at `../docs/guide` resolve.)
 */

callback("onToolCallStart") as data {
  print(
    color.yellow("tool call: ${data.toolName}(${JSON.stringify(data.args)})"),
  )
}

callback("onToolCallEnd") as data {
  print(
    color.yellow(
    "tool return: ${data.toolName} -> ${JSON.stringify(data.result)} ${data.timeTaken}ms",
  ),
  )
}

// Bundled docs live one level above the agent's compiled JS. Built once
// at module load — `skillsDir` reads + parses every `.md` file's
// frontmatter and bakes a description listing all available skills into
// the returned tool. `static` caches this across runs; `with approve`
// auto-approves the init-time `glob` and `read` interrupts (the binding
// itself is the user opt-in).
static const docSkill = skillsDir("../docs/guide") with approve

// Per-run policy: starts empty, grows as the user opts into
// always-approve / always-reject for each interrupt kind. Lives at
// module scope so the handler in `node main` and any helpers
// can read AND mutate it during a run. Module-level `let` is
// stored in the GlobalStore, which Agency reinitializes per run.
let policy: Policy = {}

// Working directory the LLM's file-system tools resolve against.
// Defaults to "." (the agent's own module dir, per Agency's stdlib
// module-relative path policy). `setCwd` mutates this; the
// `agentRead` / `agentWrite` / `agentEdit` wrappers read from it on
// every call, so a `setCwd` inside one LLM turn takes effect for
// subsequent tool calls within the same turn.
let currentDir: string = cwd()

def setCwd(dir: string): string {
  """
  Use this when the user tells you to change your current working directory. After you call this, all `agentRead` / `agentWrite` / `agentEdit` / `agentMultiEdit` calls will resolve filenames against the given directory. Use `cwd` to set to the user's cwd.

  @param dir - The directory to anchor file operations against
  """
  if (dir == "cwd") {
    dir = cwd()
  }
  currentDir = dir
  return "Working directory set to: ${dir}"
}

def agentRead(filename: string): Result {
  """
  Read a file from the agent's current working directory (see `setCwd`).

  @param filename - Path relative to the current working directory
  """
  return read(filename, currentDir)
}

def agentWrite(filename: string, content: string): Result {
  """
  Write a file inside the agent's current working directory (see `setCwd`).
  Overwrites the existing file if any.

  @param filename - Path relative to the current working directory
  @param content - File contents
  """
  return write(filename, content, currentDir)
}

def agentEdit(
  filename: string,
  oldText: string,
  newText: string,
  replaceAll: boolean = false,
): Result {
  """
  Edit a file in the agent's current working directory (see `setCwd`)
  by replacing `oldText` with `newText`.

  @param filename - Path relative to the current working directory
  @param oldText - Text to find
  @param newText - Replacement text
  @param replaceAll - If true, replace every occurrence; otherwise oldText must match exactly once
  """
  return edit(filename, oldText, newText, replaceAll, currentDir)
}

type AgentEdit = {
  oldText: string;
  newText: string;
  replaceAll: boolean
}

def agentMultiEdit(filename: string, edits: AgentEdit[]): Result {
  """
  Apply a sequence of edits to a single file atomically, relative to
  the agent's current working directory (see `setCwd`).

  @param filename - Path relative to the current working directory
  @param edits - Array of edits, each with oldText, newText, and replaceAll
  """
  return multiedit(filename, edits, currentDir)
}

type Decision =
  | "approve"
  | "reject"
  | "approve-always"
  | "reject-always"

def askUser(intr: any): Decision {
  """
  Pretty-print an interrupt and ask the user how to respond. Returns
  one of the four Decision strings.
  """
  print(color.yellow("───────────────────────────────────────────"))
  print(color.yellow("Tool wants to run: ${intr.kind}"))
  print(color.yellow("Reason: ${intr.message}"))
  print("Data:")
  printJSON(intr.data)
  print(color.yellow("───────────────────────────────────────────"))
  let answer = ""
  while (answer != "a" && answer != "r" && answer != "aa" && answer != "rr") {
    answer = input("(a)pprove / (r)eject / (aa) approve-always / (rr) reject-always: ")
  }
  if (answer == "a") {
    return "approve"
  }
  if (answer == "r") {
    return "reject"
  }
  if (answer == "aa") {
    return "approve-always"
  }
  return "reject-always"
}

def recordAlways(kind: string, action: string) {
  """
  Add an unconditional rule for `kind` to the running policy. First-match-
  wins inside `checkPolicy`, so prepending a new entry would also work,
  but a single bare rule covers every future interrupt of this kind
  cleanly.
  """
  const next: Policy = {
    ...policy,
    [kind]: [{
      action: action
    }]
  }
  policy = next
  print(
    color.cyan("→ Recorded policy: ${kind} = ${action} (won't ask again this session)"),
  )
}

def defaultHandler(intr) {
  // Consult the running policy first. If a previous "always"
  // decision covers this kind, use it without bothering the user.
  const decision = checkPolicy(policy, intr)
  if (decision.type == "approve") {
    print(color.cyan("→ policy auto-approved ${intr.kind}"))
    return approve()
  }
  if (decision.type == "reject") {
    print(color.cyan("→ policy auto-rejected ${intr.kind}"))
    return reject()
  }
  // checkPolicy returned propagate — no rule for this kind yet,
  // so ask the user and possibly record a new rule.
  const answer = askUser(intr)
  if (answer == "approve-always") {
    recordAlways(intr.kind, "approve")
    return approve()
  }
  if (answer == "reject-always") {
    recordAlways(intr.kind, "reject")
    return reject()
  }
  if (answer == "approve") {
    return approve()
  }
  // Interactive reject: give the user a chance to tell the LLM what
  // was wrong with the suggestion. The reason becomes the tool's
  // return value on the LLM side, so the model sees concrete
  // feedback ("the path is wrong" / "use a different API") instead
  // of an opaque rejection it can't learn from.
  const reason = input("Why are you rejecting? (press enter to skip) ")
  if (reason == "") {
    return reject()
  }
  return reject(reason)
}

node main() {
  print(color.cyan("╭───────────────────────────────────────────╮"))
  print(color.cyan("│       Welcome to the Agency Agent         │"))
  print(color.cyan("│  I help you write and edit .agency code.  │"))
  print(color.cyan("╰───────────────────────────────────────────╯"))
  print("Type 'exit' to quit.\n")

  const sysPrompt = """
  You are an Agency-language coding assistant. Help the user create or
  modify `.agency` files.

  Agency is a domain-specific language for AI agents. When you need to
  recall syntax, semantics, or a particular feature, call the
  bundled docs tool first — it gives you access to the full guide.

  Workflow:
  1. First, call `setCwd` with the user's project directory. After
     that, every `agentRead` / `agentWrite` / `agentEdit` /
     `agentMultiEdit` resolves filenames against that directory —
     you don't have to pass a directory each time.
  2. Use `agentRead` to inspect existing code.
  3. Always call `typecheck` on any source you produce before showing
     it to the user. If the typecheck reports errors, fix them and
     check again. Don't show broken code.
  4. Use `agentWrite` / `agentEdit` / `agentMultiEdit` to persist
     changes. The user will be prompted to approve every write.

  Keep replies brief. Show code, not commentary.
  """

  thread {
    systemMessage(sysPrompt)
    let userMsg = input("What would you like to do? ")
    while (userMsg != "exit" && userMsg != "quit") {
      handle {
        const reply = llm(
          userMsg,
          {
          tools: [
            setCwd,
            agentRead,
            agentWrite,
            agentEdit,
            agentMultiEdit,
            typecheck,
            docSkill,
            highlight.partial(language: "ts"),
          ]
        },
        )
        print(color.green("\n${reply}\n"))
      } with defaultHandler
      userMsg = input("\nNext request (or 'exit'): ")
    }
  }
  print(color.cyan("\nGoodbye!"))
  return "done"
}
