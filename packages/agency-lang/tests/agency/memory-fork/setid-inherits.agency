import { enableMemory, setMemoryId, getMemoryId } from "std::memory"

// Branch-scoped memory: each fork branch INHERITS the memory id set at
// the top level at fork time (until it sets its own).
node main() {
  enableMemory({ dir: ".agency-tmp/memory-fork-setid-inherits" }) with approve
  setMemoryId("base")
  const results = fork([1, 2, 3]) as i {
    return getMemoryId()
  }
  return results
}
