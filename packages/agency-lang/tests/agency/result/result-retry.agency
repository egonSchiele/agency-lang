import { getMutable, setMutable } from "../../helpers/mutableVar.js"

def flaky(input: string): Result {
  setMutable("attempt", getMutable("attempt", 0) + 1)
  if (getMutable("attempt", 0) < 3) {
    return failure("not yet")
  }
  return success(input)
}

node main() {
  let result = flaky("hello")
  if (isFailure(result)) {
    restore(result.checkpoint, { args: { input: "hello" } })
  }
  return { value: result.value, attempts: getMutable("attempt", 0) }
}
