import { box, text, render } from "std::layout"

// Build a styled tree once, render with color: true and color: false,
// then assert structural properties that prove `false` strips styling
// while preserving content + visual width.
//
// We check for the real CSI prefix `[` (ESC + "[") rather than a
// bare "[", so test content can later include the literal "[" without
// breaking the test.

def _styledTree(): any {
  return box(title: "T", titleColor: "blue", borderColor: "red") as b {
    b.text("hi", fgColor: "red", bold: true)
  }
}

const CSI: string = "["

// `color: true` output must contain real CSI sequences.
node testColorTrueHasSGR(): boolean {
  const out = render(_styledTree(), color: true)
  return out.indexOf(CSI) >= 0
}

// `color: false` output must be free of any CSI byte pair.
node testColorFalseStripsSGR(): boolean {
  const out = render(_styledTree(), color: false)
  return out.indexOf(CSI) == -1
}

// Stripping does not remove printed characters. The plain text
// content is still present in the colored output too.
node testContentPresentInBoth(): boolean {
  const c = render(_styledTree(), color: true)
  const p = render(_styledTree(), color: false)
  return (c.indexOf("hi") >= 0) && (p.indexOf("hi") >= 0)
}
