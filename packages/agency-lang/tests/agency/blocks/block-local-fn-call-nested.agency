def run(b: () -> void) {
  b()
}

def addTwo(a: number, b: number): number {
  return a + b
}

node main(): number {
  let result = 0
  run() as {
    // add5 is owned by the OUTER block
    let add5 = addTwo.partial(a: 5)
    run() as {
      // call the outer block's function variable (callee at depth 1)
      result = add5(10)
    }
  }
  return result
}
