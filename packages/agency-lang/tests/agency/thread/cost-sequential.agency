import { getCost } from "std::thread"

// Pinned to the deterministic LLM provider via "useTestLLMProvider":
// true in the .test.json. Each llm() call adds SYNTHETIC_COST
// (= 0.000002 USD) to the active stack — see
// lib/runtime/deterministicClient.ts. Asserting against this constant
// (rather than the raw literal in the expectedOutput) keeps the
// fixture's intent obvious if the synthetic price ever changes.
const DETERMINISTIC_COST = 0.000002

node main() {
  let before = getCost()
  llm("a")
  let after1 = getCost()
  llm("b")
  let after2 = getCost()
  let firstMatches = (after1 - before) == DETERMINISTIC_COST
  let secondMatches = (after2 - after1) == DETERMINISTIC_COST
  return "${before}_${firstMatches}_${secondMatches}"
}
