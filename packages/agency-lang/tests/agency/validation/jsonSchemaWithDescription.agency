// Regression test: when an object property has both a property-level
// description AND a @jsonSchema(...) annotation on its type alias,
// BOTH must appear in the generated JSON Schema. This guards the
// invariant that `.meta(...)` is the final Zod chain call (otherwise
// the metadata is dropped by toJSONSchema).

@jsonSchema({ format: "email" })
type Email = string

type User = {
  @jsonSchema({ description: "primary contact address" })
  contact: Email
}

node main() {
  const s = schema(User)
  const js = s.toJSONSchema()
  return js.properties.contact.format + "|" + js.properties.contact.description
}
