def tryParse(input: string): Result {
  if (input == "ok") {
    return success(42)
  }
  return failure("bad input")
}

def classify(input: string): any {
  let r = tryParse(input)
  let out = "unreachable"
  match (r is success(v)) {
    v > 10 => out = "big"
    _ => out = "small"
  }
  return out
}

node main() {
  let r1 = classify("ok")
  let r2 = classify("bad")
  return [r1, isFailure(r2)]
}
