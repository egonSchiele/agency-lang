/*
 * Tests for planModels' provider-routing rule: OpenAI is always promoted to
 * the Responses API (both fast and slow) so hosted web_search works on the
 * agent's default models. Other providers are unchanged.
 */
import { planModels, resolveDetected, ModelPlan, parseModelSpec, ModelSpec, priceDefault, Resolved, parseModelFlag } from "../lib/models.agency"

static const KNOWN = ["openai", "anthropic", "google", "openrouter", "litellm"]

def okR(r: Result<Resolved>): Resolved {
  if (isFailure(r)) {
    return { model: "ERR", provider: "ERR", via: "ERR" }
  }
  return r.value
}

node openaiDetectedRoutesBothToResponses(): ModelPlan {
  return planModels("", "", "", "", "openai")
}

node anthropicDetectedKeepsNative(): ModelPlan {
  return planModels("", "", "", "", "anthropic")
}

node explicitOpenaiModelStillRoutedThroughResponses(): ModelPlan {
  return planModels("gpt-4o", "", "", "openai", "openai")
}

// `--provider openrouter` alone resolves to the baked open-model defaults,
// both routed through the openrouter provider (no Responses promotion).
node openrouterDetectedUsesDefaults(): ModelPlan {
  return planModels("", "", "", "openrouter", "openrouter")
}

// litellm has no built-in defaults (deployment-specific model names), so
// `--provider litellm` with no model is an error — caught before any env
// read, so this is deterministic regardless of LITELLM_* env vars.
node litellmWithoutModelIsError(): boolean {
  const r = resolveDetected("", "", "", "litellm")
  if (r is failure(f)) {
    return true
  }
  return false
}

node specSplitOnKnownProvider(): ModelSpec { return parseModelSpec("anthropic/claude-opus-4-8", false, KNOWN) }
node specOpenrouterMultiSegment(): ModelSpec { return parseModelSpec("openrouter/deepseek/deepseek-r1", false, KNOWN) }
node specProviderEstablishedNoSplit(): ModelSpec { return parseModelSpec("deepseek/deepseek-r1", true, KNOWN) }
node specBareModel(): ModelSpec { return parseModelSpec("gpt-5.5", false, KNOWN) }
node specUnknownPrefixNoSplit(): ModelSpec { return parseModelSpec("unknown-vendor/some-model", false, KNOWN) }

node priceMainAnthropic(): Resolved { return okR(priceDefault("anthropic", "main", "standard")) }
node priceReasoningAnthropic(): Resolved { return okR(priceDefault("anthropic", "reasoning", "standard")) }
node priceMainOpenaiPromoted(): Resolved { return okR(priceDefault("openai", "main", "standard")) }
node priceEmbeddingDerived(): Resolved { return okR(priceDefault("anthropic", "embedding", "standard")) }
node priceUnknownProviderFails(): boolean { return isFailure(priceDefault("litellm", "main", "standard")) }

node modelFlagPerSlot(): { slot: string; model: string } { return parseModelFlag("reasoning=claude-opus-4-8") }
node modelFlagGlobal(): { slot: string; model: string } { return parseModelFlag("gpt-5.5") }
node modelFlagAliasFast(): { slot: string; model: string } { return parseModelFlag("fast=gpt-4o") }
node modelFlagUnifiedNoMissplit(): { slot: string; model: string } { return parseModelFlag("anthropic/claude-opus-4-8") }
