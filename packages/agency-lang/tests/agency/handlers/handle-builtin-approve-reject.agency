const log = []

def foo() {
  log.push("foo start")
  return interrupt("check")
  log.push("foo end")
  return "foo result"
}

def fooWithAssign() {
  log.push("foo start")
  const result = interrupt("check")
  log.push("foo end")
  return result
}

node testWithApprove() {
  handle {
    const result = foo()
    log.push(result)
  } with approve
  return log
}

node testWithReject() {
  handle {
    const result = foo()
    if (isFailure(result)) {
      log.push(result.error)
    } else {
      log.push(result)
    }
  } with reject
  return log
}

node testWithApproveAssigned() {
  handle {
    const result = fooWithAssign()
    log.push(result)
  } with approve
  return log
}

node testWithRejectAssigned() {
  handle {
    const result = fooWithAssign()
    if (isFailure(result)) {
      log.push(result.error)
    } else {
      log.push(result)
    }
  } with reject
  return log
}
