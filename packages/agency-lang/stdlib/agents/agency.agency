/** @module
  Agency-coding agent: writes an Agency program for a task, runs it, and
  verifies the program's actual result satisfies the task. Built on
  writeAgency + runCode. Composable — call it directly or from another agent.
*/
import { writeAgency, runCode, feedbackHasErrors, renderFeedback, Feedback, WriteFailure } from "std::agency"
import { guard } from "std::thread"

// One attempt's judgment: is the run's result acceptable, and if not, why.
type AttemptOutcome = {
  done: boolean;
  feedback: string
}

// Loop state, threaded through plain helpers so no `match` lives in the
// stepped `while` body (which the stepped-loop codegen mishandles).
type StepState = {
  result: Result<string, WriteFailure>;
  done: boolean
}

def failedToRun(err: any): AttemptOutcome {
  return { done: false, feedback: "The program failed to run: ${err}" }
}

// Judge the program's ACTUAL result against the task (its deliverable is the
// return value, not a disk artifact — so the disk-running `verify` is wrong here).
def outcomeFromJudge(task: string, data: any): AttemptOutcome {
  const items: Feedback[] = llm("Does this program's result satisfy the task? One Feedback item per finding; error=true if it fails the task (name it), error=false for a satisfied point.\n\nTask: ${task}\n\nResult: ${data}")
  const fb = success(items)
  const failed = feedbackHasErrors(fb)
  const detail = if failed then renderFeedback(fb) else ""
  return { done: !failed, feedback: detail }
}

def judgeRun(task: string, src: string): AttemptOutcome {
  return match (runCode(src)) {
    failure(err) => failedToRun(err)
    success(data) => outcomeFromJudge(task, data)
  }
}

def keepResult(state: StepState): StepState {
  return { result: state.result, done: true }
}

def advanceFromSource(task: string, context: string, state: StepState, src: string): StepState {
  const outcome = judgeRun(task, src)
  if (outcome.done) {
    return { result: state.result, done: true }
  }
  const extra = "${context}\n\nA prior attempt had these problems; fix them:\n${outcome.feedback}"
  return { result: writeAgency(task, extra), done: false }
}

def stepOnce(task: string, context: string, state: StepState): StepState {
  return match (state.result) {
    failure(_) => keepResult(state)
    success(src) => advanceFromSource(task, context, state, src)
  }
}

export def agencyCodingAgent(task: string, context: string = "", maxCost: number = $50.00, maxTime: number = 10m): Result<string, WriteFailure> {
  """
  Writes an Agency program for the task, runs it, and verifies its result
  satisfies the task. Returns source that compiles, typechecks, and passes
  verification.

  @param task - What the generated program should do.
  @param context - Optional extra material.
  @param maxCost - Hard spend cap for the whole run (default $50).
  @param maxTime - Hard wall-clock cap for the whole run (default 10 minutes).
  """
  const captured = guard(cost: maxCost, time: maxTime) as {
    let state: StepState = { result: writeAgency(task, context), done: false }
    let attemptsLeft = 2
    while (!state.done && attemptsLeft > 0) {
      state = stepOnce(task, context, state)
      attemptsLeft = attemptsLeft - 1
    }
    return state.result
  }
  return match (captured) {
    success(r) => r
    failure(_) => failure({ source: "", errors: [] })
  }
}
