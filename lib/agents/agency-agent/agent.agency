systemPrompt = read("./prompts/system.md")
planPrompt = read("./prompts/plan.md")

type NextAction = { type: "askUser"; question: string } | { type: "done" } | { type: "start" }

config = { 
  model: "gpt-4o",
  responseFormatOptions: { 
    strict: true,
    numRetries: 4,
    allowExtraKeys: true
  }
}
