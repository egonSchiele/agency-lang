import { _fetch, _fetchJSON, _webfetch } from "./lib/http.js"

export def fetch(url: string): string {
  """
  Fetch a URL and return the response body as text.
  """
  return interrupt({
    type: "std::http.fetch",
    message: "Are you sure you want to fetch this URL?",
    url: url
  })
  return _fetch(url)
}

export def fetchJSON(url: string) {
  """
  Fetch a URL and parse the response body as JSON.
  """
  return interrupt({
    type: "std::http.fetchJSON",
    message: "Are you sure you want to fetch this URL as JSON?",
    url: url
  })
  return _fetchJSON(url)
}

export def webfetch(url: string): string {
  """
  Fetch a URL and return the body as readable markdown when the response is HTML, or as plain text otherwise. Useful for extracting page content for an LLM.
  """
  return interrupt({
    type: "std::http.webfetch",
    message: "Are you sure you want to fetch this URL?",
    url: url
  })
  return _webfetch(url)
}
