import { sendSms } from "std::sms"

// currently skipped:
// endSms failed: Twilio API error (400): Account is inactive

node main() {
  handle {
    const result = sendSms(
      to: "+14108675310",
      body: "Agency CI test message",
      allowList: ["+14108675310"]
    )
    if (isFailure(result)) {
      return "sendSms failed: " + result.error
    }
    return "sms ok"
  } with (data) {
    return approve()
  }
}
