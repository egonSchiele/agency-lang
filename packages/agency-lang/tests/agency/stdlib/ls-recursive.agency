import { ls } from "std::shell"
import { sortBy, map } from "std::array"

node main() {
  const entries = ls("tests/agency/stdlib/glob-fixtures", true) catch [] with approve
  let sorted = sortBy(entries) as e {
    return e.path
  }
  let paths = map(sorted) as e {
    return e.path
  }
  return paths
}
