def tryParse(input: string): Result {
  if (input == "ok") {
    return success(42)
  }
  return failure("invalid input")
}

node main() {
  let r1 = tryParse("ok")
  let r2 = tryParse("bad")
  if (isSuccess(r1)) {
    if (isFailure(r2)) {
      return "both correct"
    }
  }
  return "unexpected"
}
