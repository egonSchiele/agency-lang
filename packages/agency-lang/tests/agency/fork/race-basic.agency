def identity(n: number): number {
  return n
}

node main() {
  const arr = [10, 20, 30]
  let result = race(arr) as item {
    return identity(item)
  }
  // race types as number | null; the null check narrows it for includes
  if (result != null && arr.includes(result)) {
    return true
  }
  return false
}