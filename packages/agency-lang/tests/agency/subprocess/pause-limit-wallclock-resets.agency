import { compile, run } from "std::agency"

// Wall-clock budgets are per execution SEGMENT: each fork gets a fresh
// timer, and user thinking time never counts (the child has exited while
// paused). Each segment sleeps ~1.2s under a 2s cap, but the segments sum
// past the cap — the run must still succeed.
node main() {
  const source = """
import { bash } from "std::shell"
node main() {
  let r1 = bash("sleep 1.2 && echo one")
  let r2 = bash("sleep 1.2 && echo two")
  return r1.stdout + r2.stdout
}
"""
  const compileResult = compile(source)
  if (isFailure(compileResult)) {
    return "compile failed"
  }
  handle {
    const result = run(compiled: compileResult.value, node: "main", wallClock: 2s)
    if (isSuccess(result)) {
      return result.value.data
    }
    return "run failed"
  } with (e) {
    if (e.effect == "std::run") {
      return approve()
    }
  }
}
