def riskyAction(action: string): string {
  return interrupt("Agent wants to perform: ${action}")
  return "Performed: ${action}"
}

def safeAction(x: string): string {
  return "${x} done"
}

node main() {
  uses riskyAction, safeAction
  const result: string = llm("Do something risky and something safe")
  print(result)
}

