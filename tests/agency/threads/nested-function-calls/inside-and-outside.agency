def canYouRepeatThat() {
  return llm("What was the last message from you?")
}

node main() {
  const res1 = canYouRepeatThat()
  const msgs = thread {
    const res2: number[] = llm("What is the first prime number > 100?")
    const res3 = canYouRepeatThat()
  }
  const res4 = canYouRepeatThat()

  return {
    res1: res1,
    res2: res2,
    res3: res3,
    res4: res4
  }
}